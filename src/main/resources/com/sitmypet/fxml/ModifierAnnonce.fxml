<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true"
            fx:controller="com.sitmypet.controllers.ModifierAnnonceController"
            style="-fx-background-color:transparent;">
    <VBox spacing="18" style="-fx-background-color:#f5f5f5;">
        <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>

        <HBox alignment="CENTER_LEFT">
            <Label text="✏️ Modifier une annonce"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#2d2d2d;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink fx:id="btnRetour" text="← Fermer" onAction="#handleRetour"
                       style="-fx-font-size:13px;-fx-text-fill:#7c5cbf;"/>
        </HBox>

        <VBox spacing="6">
            <Label text="Animal" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
            <ComboBox fx:id="comboAnimal" promptText="Choisir un animal" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="10">
            <Label text="Type de garde" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
            <HBox spacing="12">
                <fx:define><ToggleGroup fx:id="typeGardeGroup"/></fx:define>
                <RadioButton fx:id="radioChezMoi" text="Chez moi" toggleGroup="$typeGardeGroup"
                             userData="CHEZ_MOI" onAction="#handleTypeGardeChange"/>
                <RadioButton fx:id="radioEnChenil" text="En chenil" toggleGroup="$typeGardeGroup"
                             userData="EN_CHENIL" onAction="#handleTypeGardeChange"/>
            </HBox>
        </VBox>

        <VBox fx:id="sectionVisites" spacing="10" managed="false" visible="false">
            <VBox spacing="6">
                <Label text="Visites / jour" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                <TextField fx:id="fieldVisitesJour" promptText="Nombre de visites par jour"/>
            </VBox>
            <VBox fx:id="listeVisites" spacing="8"/>
            <Button text="+ Ajouter une visite" onAction="#handleAjouterVisite"
                    style="-fx-background-color:#2bbfa0;-fx-text-fill:white;"/>
        </VBox>

        <HBox spacing="20">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Date début"/>
                <DatePicker fx:id="dateDebut" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Date fin"/>
                <DatePicker fx:id="dateFin" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <HBox spacing="20">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Rémunération min"/>
                <TextField fx:id="fieldRemuMin" promptText="0.00"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Rémunération max"/>
                <TextField fx:id="fieldRemuMax" promptText="0.00"/>
            </VBox>
        </HBox>

        <VBox spacing="6">
            <Label text="Adresse"/>
            <TextField fx:id="fieldAdresse"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Service"/>
            <TextField fx:id="fieldService"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
            <Button fx:id="btnEnregistrer" text="Enregistrer" onAction="#handleEnregistrer"
                    style="-fx-background-color:#f5a623;-fx-text-fill:white;-fx-padding:10 28;"/>
        </HBox>
    </VBox>
</ScrollPane>
