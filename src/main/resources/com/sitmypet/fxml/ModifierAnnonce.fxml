<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true"
            fx:controller="com.sitmypet.controllers.ModifierAnnonceController"
            style="-fx-background-color: -color-bg-main;"
            stylesheets="/style.css">
    <VBox spacing="18" style="-fx-background-color: -color-bg-main;">
        <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>

        <HBox alignment="CENTER_LEFT">
            <Label text="✏️ Modifier une annonce"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink fx:id="btnRetour" text="← Fermer" onAction="#handleRetour"
                       style="-fx-font-size:13px;-fx-text-fill:#7c5cbf;"/>
        </HBox>

        <VBox spacing="6">
        <VBox spacing="6">
            <Label text="Animal" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
            <ComboBox fx:id="comboAnimal" promptText="Choisir un animal" maxWidth="Infinity" styleClass="combo-box"/>
        </VBox>

        <VBox spacing="10">
        <VBox spacing="10">
            <Label text="Type de garde" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
            <HBox spacing="12">
                <fx:define><ToggleGroup fx:id="typeGardeGroup"/></fx:define>
                <RadioButton fx:id="radioChezMoi" text="Chez moi" toggleGroup="$typeGardeGroup"
                             userData="CHEZ_MOI" onAction="#handleTypeGardeChange" style="-fx-text-fill: -color-text-main;"/>
                <RadioButton fx:id="radioEnChenil" text="En chenil" toggleGroup="$typeGardeGroup"
                             userData="EN_CHENIL" onAction="#handleTypeGardeChange" style="-fx-text-fill: -color-text-main;"/>
            </HBox>
        </VBox>

        <VBox fx:id="sectionVisites" spacing="10" managed="false" visible="false">
        <VBox fx:id="sectionVisites" spacing="10" managed="false" visible="false">
            <VBox spacing="6">
                <Label text="Visites / jour" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
                <TextField fx:id="fieldVisitesJour" promptText="Nombre de visites par jour" styleClass="text-field"/>
            </VBox>
            <VBox fx:id="listeVisites" spacing="8"/>
            <Button text="+ Ajouter une visite" onAction="#handleAjouterVisite" styleClass="button, btn-info"/>
        </VBox>

        <HBox spacing="20">
        <HBox spacing="20">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Date début" style="-fx-text-fill: -color-text-main;"/>
                <DatePicker fx:id="dateDebut" maxWidth="Infinity" styleClass="text-field"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Date fin" style="-fx-text-fill: -color-text-main;"/>
                <DatePicker fx:id="dateFin" maxWidth="Infinity" styleClass="text-field"/>
            </VBox>
        </HBox>

        <HBox spacing="20">
        <HBox spacing="20">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Rémunération min" style="-fx-text-fill: -color-text-main;"/>
                <TextField fx:id="fieldRemuMin" promptText="0.00" styleClass="text-field"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Rémunération max" style="-fx-text-fill: -color-text-main;"/>
                <TextField fx:id="fieldRemuMax" promptText="0.00" styleClass="text-field"/>
            </VBox>
        </HBox>

        <VBox spacing="6">
        <VBox spacing="6">
            <Label text="Adresse" style="-fx-text-fill: -color-text-main;"/>
            <TextField fx:id="fieldAdresse" styleClass="text-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Service" style="-fx-text-fill: -color-text-main;"/>
            <TextField fx:id="fieldService" styleClass="text-field"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
        <HBox alignment="CENTER_RIGHT">
            <Button fx:id="btnEnregistrer" text="Enregistrer" onAction="#handleEnregistrer" styleClass="button, btn-primary"
                    style="-fx-padding: 10 28;"/>
        </HBox>
    </VBox>
</ScrollPane>
