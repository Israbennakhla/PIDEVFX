<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sitmypet.controllers.CreerAnnonceController"
      prefWidth="900" prefHeight="800"
      style="-fx-background-color: #f5f5f5;">

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:transparent;">
        <VBox spacing="18" style="-fx-background-color:#f5f5f5;">
            <padding><Insets top="20" right="60" bottom="20" left="60"/></padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="📣 Créer une annonce"
                       style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#2d2d2d;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink fx:id="btnRetour" text="← Retour" onAction="#handleRetour"
                           style="-fx-font-size:13px;-fx-text-fill:#7c5cbf;"/>
            </HBox>

            <VBox spacing="6">
                <Label text="Animal" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                <ComboBox fx:id="comboAnimal" promptText="Choisir un animal" maxWidth="Infinity"
                          style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;
                                 -fx-background-radius:8px;-fx-padding:6px 10px;-fx-font-size:13px;"/>
            </VBox>

            <VBox spacing="10">
                <Label text="Type de garde" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                <HBox spacing="12">
                    <fx:define><ToggleGroup fx:id="typeGardeGroup"/></fx:define>
                    <RadioButton fx:id="radioChezMoi" text="Chez moi" toggleGroup="$typeGardeGroup"
                                 userData="CHEZ_MOI" onAction="#handleTypeGardeChange"
                                 style="-fx-background-color:white;-fx-background-radius:10px;-fx-border-color:#cccccc;
                                        -fx-border-radius:10px;-fx-padding:10 20;-fx-text-fill:#333;"/>
                    <RadioButton fx:id="radioEnChenil" text="En chenil" toggleGroup="$typeGardeGroup"
                                 userData="EN_CHENIL" onAction="#handleTypeGardeChange"
                                 style="-fx-background-color:white;-fx-background-radius:10px;-fx-border-color:#cccccc;
                                        -fx-border-radius:10px;-fx-padding:10 20;-fx-text-fill:#333;"/>
                </HBox>
            </VBox>

            <VBox fx:id="sectionVisites" spacing="10" managed="false" visible="false">
                <VBox spacing="6">
                    <Label text="Visites / jour" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <TextField fx:id="fieldVisitesJour" promptText="Nombre de visites par jour"
                               style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;
                                      -fx-background-radius:8px;-fx-padding:8px 10px;"/>
                </VBox>
                <VBox fx:id="listeVisites" spacing="8"/>
                <Button text="+ Ajouter une visite" onAction="#handleAjouterVisite"
                        style="-fx-background-color:#2bbfa0;-fx-text-fill:white;-fx-font-size:13px;
                               -fx-font-weight:bold;-fx-background-radius:20px;-fx-padding:9 20;-fx-cursor:hand;"/>
            </VBox>

            <HBox spacing="20">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Date début" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <DatePicker fx:id="dateDebut" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Date fin" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <DatePicker fx:id="dateFin" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <HBox spacing="20">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Rémunération min" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <TextField fx:id="fieldRemuMin" promptText="0.00"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Rémunération max" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <TextField fx:id="fieldRemuMax" promptText="0.00"/>
                </VBox>
            </HBox>

            <VBox spacing="8">
                <Label text="Adresse (cliquez sur la carte pour localiser)"
                       style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="fieldAdresse" editable="false"
                               promptText="Cliquez sur la carte..."
                               maxWidth="Infinity"
                               style="-fx-background-color:#f0f0f8;-fx-border-color:#9b72e8;
                                      -fx-border-radius:8px;-fx-background-radius:8px;
                                      -fx-padding:8px 12px;-fx-font-size:13px;-fx-text-fill:#333;"/>
                    <HBox.hgrow><Priority fx:constant="ALWAYS"/></HBox.hgrow>
                    <Button fx:id="btnResetMap" text="✕ Effacer" onAction="#handleResetAdresse"
                            style="-fx-background-color:#eeeeee;-fx-text-fill:#666;-fx-font-size:12px;
                                   -fx-background-radius:8px;-fx-padding:8 14;-fx-cursor:hand;"/>
                </HBox>

                <VBox style="-fx-background-radius:12px;-fx-border-color:#9b72e8;-fx-border-radius:12px;
                             -fx-border-width:2;">
                    <WebView fx:id="mapView" prefHeight="320" minHeight="280"/>
                </VBox>
            </VBox>

            <VBox spacing="6">
                <Label text="Service" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                <TextField fx:id="fieldService"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Créer" onAction="#handleCreer"
                        style="-fx-background-color:linear-gradient(to right,#9b72e8,#7c5cbf);
                               -fx-text-fill:white;-fx-font-size:14px;-fx-font-weight:bold;
                               -fx-background-radius:20px;-fx-padding:10 35;-fx-cursor:hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
