<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import com.sitmypet.components.SmallThemeToggle?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sitmypet.controllers.AdminAnnoncesController" stylesheets="@../css/style.css" prefHeight="750.0" prefWidth="1300.0">
    <!-- SIDEBAR GAUCHE -->
    <left>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: transparent; -fx-background-color: transparent;" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox styleClass="sidebar" prefWidth="260" spacing="10">
                    <VBox alignment="CENTER_LEFT" spacing="5" style="-fx-padding: 25 20 15 20;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🐾" style="-fx-font-size: 26px; -fx-text-fill: #a274db;"/>
                            <Label text="SitMyPet" styleClass="sidebar-logo-text"/>
                        </HBox>
                        <Label text="PANNEAU ADMIN" styleClass="sidebar-subtitle"/>
                        <Region prefHeight="10"/>
                        <SmallThemeToggle />
                    </VBox>
                    
                    <Separator styleClass="sidebar-separator" />
                    
                    <VBox spacing="5" style="-fx-padding: 10 15 5 15;">
                        <Label text="PRINCIPAL" styleClass="sidebar-section"/>
                        <Button text="⏱ Dashboard" onAction="#handleRetour" styleClass="sidebar-btn"/>
                    </VBox>
                    
                    <VBox spacing="5" style="-fx-padding: 5 15 5 15;">
                        <Label text="GESTION" styleClass="sidebar-section"/>
                        <Button text="👥 Utilisateurs" onAction="#handleUsers" styleClass="sidebar-btn"/>
                        <Button text="🐾 Animaux" onAction="#handleAnimaux" styleClass="sidebar-btn"/>
                        <Button text="📢 Annonces" styleClass="sidebar-btn, sidebar-active"/>
                        <Button text="📅 Événements" onAction="#handleEvenements" styleClass="sidebar-btn"/>
                        <Button text="📩 Réclamations" onAction="#handleReclamations" styleClass="sidebar-btn"/>
                    </VBox>
                    
                    <VBox spacing="5" style="-fx-padding: 10 15 5 15;">
                        <Label text="INTERFACE PUBLIQUE" styleClass="sidebar-section"/>
                        <Button text="🌍 Voir le site" styleClass="sidebar-btn"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
                    <Separator styleClass="sidebar-separator" />

                    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 20 15 5 15;">
                        <Label text="SA" styleClass="sidebar-avatar"/>
                        <VBox alignment="CENTER_LEFT" spacing="2">
                            <Label text="Super Admin" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <Label text="Administrateur" style="-fx-text-fill: #8a81ad; -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>
                    
                    <VBox style="-fx-padding: 0 15 20 15;">
                        <Button text="🚪 Se Déconnecter" onAction="#handleLogout" styleClass="sidebar-btn" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-alignment: CENTER; -fx-border-color: #3b305c; -fx-border-radius: 8; -fx-border-width: 1;"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </left>

    <!-- CONTENU CENTRAL -->
    <center>
        <VBox>
            <!-- En-tête -->
            <VBox spacing="10" style="-fx-background-color: -color-bg-surface; -fx-padding: 30 40 30 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 5);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📢" style="-fx-font-size: 32px;"/>
                    <Label text="Gestion des Annonces" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: -color-text-main;"/>
                </HBox>
                <Label text="Gérez les annonces publiées." style="-fx-font-size: 15px; -fx-text-fill: -color-text-secondary;"/>
            </VBox>

            <!-- Section Liste -->
            <HBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 20 40 30 40;">
                
                <!-- Liste des Cartes -->
                <VBox spacing="15" HBox.hgrow="ALWAYS">
                    <Label text="Liste des Annonces" styleClass="title-label" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtRecherche" promptText="Rechercher une annonce..." styleClass="search-bar" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="cbTri" promptText="Trier par" styleClass="combo-box" />
                    </HBox>
                    <ListView fx:id="listAnnonces" styleClass="custom-list-view" VBox.vgrow="ALWAYS"/>
                </VBox>

            </HBox>
        </VBox>
    </center>
</BorderPane>
