<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" style="-fx-background-color: #f8f8f8; -fx-padding: 30; -fx-min-width: 480;" stylesheets="@../css/style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.sitmypet.controllers.AjouterReponse">

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT">
        <Label styleClass="titre-page" text="💬 Ajouter une Réponse" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#annuler" styleClass="lien-retour" text="← Retour" />
    </HBox>

    <!-- Bannière violette — Auteur -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="banniere-violet">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label style="-fx-text-fill: white; -fx-font-size: 12px;" text="Nom de l'auteur" />
            <TextField fx:id="champAuteur" style="-fx-background-color: transparent;                               -fx-border-color: transparent transparent white transparent;                               -fx-border-width: 0 0 1 0;                               -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.7);" />
        </VBox>
    </HBox>
    <Label fx:id="errAuteur" style="-fx-padding: 2 0 8 0;" styleClass="label-erreur" />

    <!-- Contenu -->
    <VBox spacing="5" style="-fx-padding-top: 12;">
        <Label styleClass="label-champ" text="Contenu de la réponse" />
        <TextArea fx:id="champContenu" prefRowCount="5" promptText="Votre réponse à la réclamation..." styleClass="champ-textarea" wrapText="true" />
        <Label fx:id="errContenu" styleClass="label-erreur" />
    </VBox>

    <!-- Boutons -->
    <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding-top: 20;">
        <Button onAction="#annuler" styleClass="btn-secondaire" text="Annuler" />
        <Button onAction="#enregistrer" styleClass="btn-principal" text=" Enregistrer" />
    </HBox>
    <VBox.margin><Insets bottom="20" /></VBox.margin>

</VBox>
