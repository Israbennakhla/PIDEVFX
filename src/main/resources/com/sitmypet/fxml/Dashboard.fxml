<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.*?>
<?import com.sitmypet.components.SmallThemeToggle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sitmypet.controllers.DashboardController"
            stylesheets="/style.css"
            prefHeight="750.0" prefWidth="1300.0">

    <!-- SIDEBAR GAUCHE -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260" spacing="10">
            <!-- Logo Section -->
            <VBox alignment="CENTER_LEFT" spacing="5" style="-fx-padding: 25 20 15 20;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🐾" style="-fx-font-size: 26px; -fx-text-fill: #a274db;"/>
                    <Label text="SitMyPet" styleClass="sidebar-logo-text"/>
                </HBox>
                <Label text="PANNEAU ADMIN" styleClass="sidebar-subtitle"/>
                <Region prefHeight="10"/>
                <SmallThemeToggle />
            </VBox>
            
            <Separator styleClass="sidebar-separator" />
            
            <!-- Section Principal -->
            <VBox spacing="5" style="-fx-padding: 10 15 5 15;">
                <Label text="PRINCIPAL" styleClass="sidebar-section"/>
                <Button text="⏱ Dashboard" styleClass="sidebar-btn, sidebar-active"/>
            </VBox>
            
            <!-- Section Gestion -->
            <VBox spacing="5" style="-fx-padding: 5 15 5 15;">
                <Label text="GESTION" styleClass="sidebar-section"/>
                <Button text="👥 Utilisateurs" onAction="#handleAfficherUsers" styleClass="sidebar-btn"/>
                <Button text="🐾 Animaux" onAction="#handleNavAnimaux" styleClass="sidebar-btn"/>
                <Button text="📢 Annonces" onAction="#handleNavAnnonces" styleClass="sidebar-btn"/>
                <Button text="📋 Postulations" onAction="#handleNavPostulations" styleClass="sidebar-btn"/>
                <Button text="📅 Événements" styleClass="sidebar-btn"/>
                <Button text="📩 Réclamations" styleClass="sidebar-btn"/>
            </VBox>
            
            <!-- Section Publique -->
            <VBox spacing="5" style="-fx-padding: 10 15 5 15;">
                <Label text="INTERFACE PUBLIQUE" styleClass="sidebar-section"/>
                <Button text="🌐 Voir le site" styleClass="sidebar-btn"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            

            
            <Separator styleClass="sidebar-separator" />

            <!-- Utilisateur Connecté en bas -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 20 15 5 15;">
                <Label text="SA" styleClass="sidebar-avatar"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Super Admin" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="Administrateur" style="-fx-text-fill: #8a81ad; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
            
            <!-- Bouton de Déconnexion -->
            <VBox style="-fx-padding: 0 15 20 15;">
                <Button text="🚪 Se Déconnecter" onAction="#handleLogout" styleClass="sidebar-btn" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-alignment: CENTER; -fx-border-color: #3b305c; -fx-border-radius: 8; -fx-border-width: 1;"/>
            </VBox>
        </VBox>
    </left>


    <!-- CONTENU CENTRAL (STATS) -->
    <center>
        <VBox spacing="30" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>
            
            <VBox spacing="5">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📊" style="-fx-font-size: 36px;"/>
                    <Label text="Tableau de Bord - Statistiques" styleClass="greeting-title"/>
                </HBox>
                <Label text="Analyse détaillée de l'activité des utilisateurs SitMyPet" styleClass="greeting-subtitle"/>
            </VBox>
            
            <!-- Graphiques -->
            <HBox spacing="40" VBox.vgrow="ALWAYS" alignment="CENTER">
                
                <VBox styleClass="user-card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" alignment="CENTER" spacing="15" maxWidth="800">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label text="Répartition par Rôles" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
                    <PieChart fx:id="chartRoles" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity" legendVisible="true" labelsVisible="true"/>
                </VBox>
                
                <VBox styleClass="user-card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" alignment="CENTER" spacing="15" maxWidth="800">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label text="Taux d'Activité" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
                    <BarChart fx:id="chartStatut" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity" legendVisible="false">
                        <xAxis>
                            <CategoryAxis label="Statut"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Nombre d'utilisateurs"/>
                        </yAxis>
                    </BarChart>
                </VBox>
                
            </HBox>
        </VBox>
    </center>
</BorderPane>
