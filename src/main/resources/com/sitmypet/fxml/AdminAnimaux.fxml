<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sitmypet.controllers.AdminAnimauxController" stylesheets="/style.css">
    <top>
        <HBox style="-fx-background-color: #2d1354; -fx-padding: 15;" alignment="CENTER_LEFT" spacing="20">
            <Button text="← Retour Dashboard" onAction="#handleRetour" style="-fx-background-color: white; -fx-text-fill: #2d1354; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Label text="🐾 Gestion des Animaux" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>
    <center>
        <TableView fx:id="tableAnimaux" style="-fx-padding: 10;">
            <columns>
                <TableColumn text="ID" prefWidth="50"><cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory></TableColumn>
                <TableColumn text="Nom" prefWidth="120"><cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory></TableColumn>
                <TableColumn text="Type" prefWidth="100"><cellValueFactory><PropertyValueFactory property="typePet"/></cellValueFactory></TableColumn>
                <TableColumn text="Race" prefWidth="120"><cellValueFactory><PropertyValueFactory property="breed"/></cellValueFactory></TableColumn>
                <TableColumn text="Genre" prefWidth="80"><cellValueFactory><PropertyValueFactory property="gender"/></cellValueFactory></TableColumn>
                <TableColumn text="Poids (kg)" prefWidth="80"><cellValueFactory><PropertyValueFactory property="weight"/></cellValueFactory></TableColumn>
                <TableColumn text="Date Naissance" prefWidth="120"><cellValueFactory><PropertyValueFactory property="birthDate"/></cellValueFactory></TableColumn>
                <TableColumn text="Vacciné" prefWidth="80"><cellValueFactory><PropertyValueFactory property="vaccinated"/></cellValueFactory></TableColumn>
            </columns>
        </TableView>
    </center>
    <right>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-width: 0 0 0 1;" prefWidth="350">
            <Label text="Formulaire Animal" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtNom" promptText="Nom de l'animal"/>
            <ComboBox fx:id="cbType" promptText="Type d'animal" maxWidth="Infinity"/>
            <TextField fx:id="txtRace" promptText="Race"/>
            <ComboBox fx:id="cbGenre" promptText="Genre" maxWidth="Infinity"/>
            <TextField fx:id="txtPoids" promptText="Poids (ex: 4.5)"/>
            <DatePicker fx:id="dpNaissance" promptText="Date de naissance" maxWidth="Infinity"/>
            <TextArea fx:id="txtDescription" promptText="Description" prefRowCount="3"/>
            
            <CheckBox fx:id="chkVaccine" text="Vacciné"/>
            <CheckBox fx:id="chkMaladie" text="Maladie contagieuse"/>
            <CheckBox fx:id="chkDossier" text="Carnet de santé dispo."/>
            <CheckBox fx:id="chkCritique" text="Condition critique"/>
            
            <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                <Button text="Vider" onAction="#handleClear" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Ajouter" onAction="#handleAjouter" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <HBox spacing="10">
                <Button text="Modifier" onAction="#handleModifier" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Supprimer" onAction="#handleSupprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </right>
</BorderPane>
