<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sitmypet.controllers.MessagerieController"
      prefWidth="1100" prefHeight="650"
      style="-fx-background-color: -color-bg-main;"
      stylesheets="/style.css">

    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <VBox prefWidth="300" minWidth="280" maxWidth="320"
              style="-fx-background-color: -color-bg-surface; -fx-border-color: -color-border transparent transparent transparent; -fx-border-width: 0 1 0 0;">

            <HBox style="-fx-background-color: -color-bg-surface-alt; -fx-padding: 16 18;
                         -fx-border-color: transparent transparent -color-border transparent; -fx-border-width: 0 0 1 0;">
                <Label text="Conversations"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <ListView fx:id="listConversations" VBox.vgrow="ALWAYS"
                      style="-fx-background-color:transparent;-fx-border-color:transparent;
                             -fx-focus-color:transparent;-fx-faint-focus-color:transparent;"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: -color-bg-main;">

            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: -color-bg-surface; -fx-padding: 14 20;
                         -fx-border-color: -color-border transparent -color-border transparent;
                         -fx-border-width: 1 0 1 0; -fx-min-height: 60; -fx-max-height: 60;">
                <Label fx:id="labelInterlocuteur" text="Sélectionnez une conversation"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: -color-text-main;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelStatut" text=""
                       style="-fx-font-size:11px;-fx-text-fill:#4caf50;-fx-font-weight:bold;"/>
            </HBox>

            <ScrollPane fx:id="scrollMessages" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: -color-bg-main; -fx-background: transparent; -fx-border-color: transparent;
                               -fx-focus-color: transparent;">
                <VBox fx:id="messagesBox" spacing="10"
                      style="-fx-background-color: transparent; -fx-padding: 16;"/>
            </ScrollPane>

            <HBox spacing="0" alignment="CENTER"
                  style="-fx-background-color: -color-bg-surface;
                         -fx-border-color: -color-border transparent transparent transparent;
                         -fx-border-width: 1 0 0 0; -fx-min-height: 70; -fx-max-height: 70;">
                <TextArea fx:id="inputField"
                          promptText="Votre message… (Entrée pour envoyer)"
                          prefRowCount="2" wrapText="true"
                          style="-fx-background-color: transparent; -fx-border-color: transparent;
                                 -fx-font-size: 13px; -fx-padding: 12 16; -fx-text-fill: -color-text-main;" HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnEnvoyer" text="Envoyer" onAction="#handleEnvoyer"
                        styleClass="button, btn-primary"
                        style="-fx-background-radius: 0; -fx-min-height: 70; -fx-max-height: 70; -fx-padding: 0 24;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
