<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sitmypet.controllers.ClientController"
            stylesheets="@../css/client.css"
            prefHeight="720.0" prefWidth="1280.0">

    <!-- ── TOP NAV BAR ─────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="20">

            <Label text="🐾 SitMyPet" styleClass="brand-label"/>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="25">
                <Label text="💼 Dashboard" styleClass="nav-link"/>
                <Label text="📢 Annonces" styleClass="nav-link"/>
                <Label text="📅 Événements" styleClass="nav-link-active"/>
                <Label text="🐾 Animaux" styleClass="nav-link"/>
                <Label text="📩 Réclamations" styleClass="nav-link"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <ComboBox fx:id="cbMockUser" onAction="#onUserChanged"/>
            <Button text="🔑 Admin" onAction="#retourAdmin" styleClass="btn-admin"/>

        </HBox>
    </top>

    <!-- ── MAIN CONTENT ─────────────────────────────────────────────────── -->
    <center>
        <VBox styleClass="page-content" VBox.vgrow="ALWAYS">
            <VBox styleClass="card" VBox.vgrow="ALWAYS">

                <!-- Header + Search Bar -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="🌐 Tous les Événements" styleClass="page-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="tfSearch" promptText="🔍 Rechercher (nom, lieu)..." 
                               styleClass="text-field" prefWidth="280" />
                </HBox>

                <!-- Event Grid (Grid View) as primary view -->
                <ScrollPane fx:id="gridScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0;">
                    <FlowPane fx:id="gridPane" hgap="20" vgap="20" style="-fx-padding: 10;" />
                </ScrollPane>

            </VBox>
        </VBox>
    </center>

</BorderPane>
