<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sitmypet.controllers.InscriptionController"
            stylesheets="/style.css"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: white; -fx-padding: 0; -fx-background: white;">
    <HBox style="-fx-background-color: white;">

    <!-- PARTIE GAUCHE (Dégradé / Branding) -->
    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity" alignment="CENTER" spacing="20"
          style="-fx-background-color: linear-gradient(to bottom right, #2d1354, #8e5bd6);">
        <Label text="🐾" style="-fx-font-size: 80px; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10);"/>
        <Label text="SitMyPet" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: white;"/>
        <Label text="Rejoignez la communauté" style="-fx-font-size: 16px; -fx-text-fill: #e9d8fd;"/>
    </VBox>

    <!-- PARTIE DROITE (Formulaire) -->
    <VBox HBox.hgrow="ALWAYS" minWidth="450" maxWidth="700" alignment="CENTER" spacing="25" style="-fx-padding: 30 50;">
        <VBox alignment="CENTER" spacing="5">
            <Label text="Inscription" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #2d1354;"/>
            <Label text="Créez votre compte en quelques clics." style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
        </VBox>

        <VBox spacing="15">
            <!-- Nom & Prénom en ligne -->
            <HBox spacing="15">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Nom *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                    <TextField fx:id="txtNom" promptText="Ex: Dupont" style="-fx-padding: 12 15; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Prénom *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                    <TextField fx:id="txtPrenom" promptText="Ex: Jean" style="-fx-padding: 12 15; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
                </VBox>
            </HBox>
            
            <!-- Email -->
            <VBox spacing="6">
                <Label text="Adresse Email *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                <TextField fx:id="txtEmail" promptText="jean.dupont@exemple.com" style="-fx-padding: 12 15; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
            </VBox>
            
            <!-- Telephone -->
            <VBox spacing="6">
                <Label text="Téléphone" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                <TextField fx:id="txtTelephone" promptText="Ex: 20 123 456" style="-fx-padding: 12 15; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
            </VBox>

            <!-- Role (Combobox) -->
            <VBox spacing="6">
                <Label text="Je suis un... *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                <ComboBox fx:id="choiceRole" maxWidth="Infinity" style="-fx-padding: 8 10; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
            </VBox>

            <!-- Upload Certificat (Gardien uniquement) -->
            <VBox fx:id="vboxCertificat" spacing="6" managed="false" visible="false">
                <Label text="Certificat ou Diplôme (Image) *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Parcourir..." onAction="#handleUploadCertificat" styleClass="button, btn-secondary" style="-fx-padding: 8 15;"/>
                    <Label fx:id="lblCertificatFile" text="Aucun fichier sélectionné" style="-fx-text-fill: #718096; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

            <!-- Mots de passe en ligne -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <HBox spacing="15">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Mot de Passe *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                        <PasswordField fx:id="txtPassword" promptText="••••••••" style="-fx-padding: 12 15; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
                        <Label fx:id="lblPasswordStrength" text="" style="-fx-font-size: 12px; -fx-padding: 2 0 0 5;" managed="true" visible="true"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Confirmer *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                        <PasswordField fx:id="txtConfirmPassword" promptText="••••••••" style="-fx-padding: 12 15; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- Section CAPTCHA -->
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #f7fafc; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
            <Label text="Vérification de sécurité *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
            <HBox alignment="CENTER" spacing="15">
                <ImageView fx:id="imgCaptcha" fitHeight="50" fitWidth="160"/>
                <Button text="🔄" onAction="#genererNouveauCaptcha" styleClass="button, btn-secondary" style="-fx-padding: 5 10;"/>
            </HBox>
            <TextField fx:id="txtCaptcha" promptText="Saisissez le texte de l'image" alignment="CENTER" style="-fx-padding: 10; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e0; -fx-background-color: white; -fx-pref-width: 200;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="15">
            <!-- Message d'erreur -->
            <Label fx:id="lblErreur" text="Veuillez remplir tous les champs." style="-fx-text-fill: #e53e3e; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-color: #fff5f5; -fx-padding: 8 15; -fx-background-radius: 8;" visible="false"/>

            <!-- Boutons -->
            <Button text="S'inscrire avec Google" onAction="#handleGoogleSignUp" maxWidth="Infinity" styleClass="button, btn-secondary" style="-fx-padding: 12 0;"/>
            
            <HBox alignment="CENTER" spacing="10">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="OU" style="-fx-text-fill: #a0aec0; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <Button text="Créer mon compte" onAction="#handleInscription" maxWidth="Infinity" styleClass="button, btn-primary" style="-fx-padding: 15 0;"/>
            
            <HBox alignment="CENTER" spacing="8">
                <Label text="Vous avez déjà un compte ?" style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
                <Label text="Se connecter" onMouseClicked="#handleGoToLogin" style="-fx-text-fill: #8e5bd6; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>
        </VBox>
    </VBox>
    </HBox>
</ScrollPane>
