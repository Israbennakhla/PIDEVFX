<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sitmypet.controllers.InscriptionController"
      stylesheets="/style.css"
      prefHeight="650.0" prefWidth="900.0"
      style="-fx-background-color: white;">

    <!-- PARTIE GAUCHE (Dégradé / Branding) -->
    <VBox prefWidth="400" alignment="CENTER" spacing="20"
          style="-fx-background-color: linear-gradient(to bottom right, #8e5bd6, #5a369e);">
        <Label text="🐾" style="-fx-font-size: 80px; -fx-text-fill: white;"/>
        <Label text="SitMyPet" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: white;"/>
        <Label text="Créez votre compte" style="-fx-font-size: 16px; -fx-text-fill: #d1cadd;"/>
    </VBox>

    <!-- PARTIE DROITE (Formulaire) -->
    <VBox prefWidth="500" alignment="CENTER" spacing="15" style="-fx-padding: 20 40;">
        <VBox alignment="CENTER" spacing="5">
            <Label text="Inscription" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #2d3748;"/>
            <Label text="Rejoignez la communauté SitMyPet" style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
        </VBox>

        <VBox spacing="10">
            <!-- Nom & Prénom en ligne -->
            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nom *" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="txtNom" promptText="Dupont" styleClass="text-field" prefHeight="40"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Prénom *" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="txtPrenom" promptText="Jean" styleClass="text-field" prefHeight="40"/>
                </VBox>
            </HBox>
            
            <!-- Email -->
            <VBox spacing="5">
                <Label text="Adresse Email *" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <TextField fx:id="txtEmail" promptText="jean.dupont@exemple.com" styleClass="text-field" prefHeight="40"/>
            </VBox>
            
            <!-- Telephone -->
            <VBox spacing="5">
                <Label text="Téléphone" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <TextField fx:id="txtTelephone" promptText="06 12 34 56 78" styleClass="text-field" prefHeight="40"/>
            </VBox>

            <!-- Role (Combobox) -->
            <VBox spacing="5">
                <Label text="Je suis un... *" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <ComboBox fx:id="choiceRole" prefWidth="420" prefHeight="40" styleClass="combo-box"/>
            </VBox>

            <!-- Mots de passe en ligne -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Mot de Passe *" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                        <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="text-field" prefHeight="40"/>
                        <Label fx:id="lblPasswordStrength" text="" style="-fx-font-size: 12px;" managed="true" visible="true"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Confirmer *" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                        <PasswordField fx:id="txtConfirmPassword" promptText="••••••••" styleClass="text-field" prefHeight="40"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- Message d'erreur -->
        <Label fx:id="lblErreur" text="Veuillez remplir tous les champs." style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 13px;" visible="false"/>

        <!-- Boutons -->
        <Button text="Créer mon compte" onAction="#handleInscription" prefWidth="420" prefHeight="45" styleClass="btn-primary" style="-fx-font-size: 16px;"/>
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="Vous avez déjà un compte ?" style="-fx-text-fill: #718096;"/>
            <Label text="Se connecter" onMouseClicked="#handleGoToLogin" style="-fx-text-fill: #8e5bd6; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </HBox>

    </VBox>
</HBox>
