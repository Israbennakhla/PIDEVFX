<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sitmypet.controllers.ModifierAnnonceController"
      prefWidth="900" prefHeight="800"
      style="-fx-background-color: #f5f5f5;">

    <!-- ===================== NAVBAR ===================== -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color:#1a0a2e;-fx-padding:0 30px;-fx-min-height:64px;-fx-max-height:64px;">
        <VBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding:0 30 0 0;">
            <Label text="SitMyPet" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:white;"/>
        </VBox>
        <Button text="Dashboard"    onAction="#handleNavDashboard"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Accueil"      onAction="#handleNavAccueil"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <!-- Postulations actif -->
        <Button text="Postulations" onAction="#handleNavPostulations"
                style="-fx-background-color:transparent;-fx-text-fill:#f5c518;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Annonces"     onAction="#handleNavAnnonces"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Evenements"   onAction="#handleNavEvenements"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Animaux"      onAction="#handleNavAnimaux"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Reclamations" onAction="#handleNavReclamations"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="👤" style="-fx-background-color:#c084fc;-fx-text-fill:white;-fx-background-radius:50%;-fx-font-size:14px;-fx-cursor:hand;-fx-padding:8 10;-fx-min-width:36;"/>
    </HBox>

    <!-- ===================== CONTENU ===================== -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="18" style="-fx-background-color: #f5f5f5;">
            <padding><Insets top="20" right="60" bottom="20" left="60"/></padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="✏️ Modifier une annonce"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink fx:id="btnRetour" text="← Retour" onAction="#handleRetour"
                           style="-fx-font-size: 13px; -fx-text-fill: #7c5cbf;"/>
            </HBox>

            <VBox spacing="6">
                <Label text="Animal" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <ComboBox fx:id="comboAnimal" promptText="Choisir un animal" maxWidth="Infinity"
                          style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:6px 10px;-fx-font-size:13px;"/>
            </VBox>

            <VBox spacing="10">
                <Label text="Type de garde" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <HBox spacing="12">
                    <fx:define><ToggleGroup fx:id="typeGardeGroup"/></fx:define>
                    <RadioButton fx:id="radioChezMoi" text="Chez moi" toggleGroup="$typeGardeGroup"
                                 userData="CHEZ_MOI" onAction="#handleTypeGardeChange"
                                 style="-fx-background-color:white;-fx-background-radius:10px;-fx-border-color:#cccccc;-fx-border-radius:10px;-fx-padding:10 20;-fx-text-fill:#333;-fx-mark-color:#4a90d9;-fx-label-padding:0 0 0 6;"/>
                    <RadioButton fx:id="radioEnChenil" text="En chenil" toggleGroup="$typeGardeGroup"
                                 userData="EN_CHENIL" onAction="#handleTypeGardeChange"
                                 style="-fx-background-color:white;-fx-background-radius:10px;-fx-border-color:#cccccc;-fx-border-radius:10px;-fx-padding:10 20;-fx-text-fill:#333;-fx-mark-color:#4a90d9;-fx-label-padding:0 0 0 6;"/>
                </HBox>
            </VBox>

            <VBox fx:id="sectionVisites" spacing="10" managed="false" visible="false">
                <VBox spacing="6">
                    <Label text="Visites / jour" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                    <TextField fx:id="fieldVisitesJour" promptText="Nombre de visites par jour"
                               style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8px 10px;"/>
                </VBox>
                <VBox fx:id="listeVisites" spacing="8"/>
                <Button text="+ Ajouter une visite" onAction="#handleAjouterVisite"
                        style="-fx-background-color:#2bbfa0;-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:20px;-fx-padding:9 20;-fx-cursor:hand;"/>
            </VBox>

            <HBox spacing="20">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Date début" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                    <DatePicker fx:id="dateDebut" maxWidth="Infinity"
                                style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Date fin" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                    <DatePicker fx:id="dateFin" maxWidth="Infinity"
                                style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;"/>
                </VBox>
            </HBox>

            <HBox spacing="20">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Rémunération min" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                    <TextField fx:id="fieldRemuMin" promptText="0.00"
                               style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8px 10px;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Rémunération max" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                    <TextField fx:id="fieldRemuMax" promptText="0.00"
                               style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8px 10px;"/>
                </VBox>
            </HBox>

            <VBox spacing="6">
                <Label text="Adresse" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="fieldAdresse"
                           style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8px 10px;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Service" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="fieldService"
                           style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8px 10px;"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnEnregistrer" text="💾 Modifier" onAction="#handleEnregistrer"
                        style="-fx-background-color:#f5a623;-fx-text-fill:white;-fx-font-size:14px;-fx-font-weight:bold;-fx-background-radius:20px;-fx-padding:10 35;-fx-cursor:hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>

    <!-- ===================== FOOTER ===================== -->
    <VBox spacing="0" style="-fx-background-color:#1a0a2e;">
        <HBox spacing="0" style="-fx-padding:25px 40px 15px 40px;">
            <VBox spacing="8" prefWidth="280">
                <Label text="SITMYPET" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="L'application pour gérer la garde des animaux et connecter propriétaires et gardiens."
                       wrapText="true" style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
            </VBox>
            <VBox spacing="6" prefWidth="200">
                <Label text="Liens rapides" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Hyperlink text="Accueil"             onAction="#handleNavDashboard"    style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Hyperlink text="Publier une annonce" onAction="#handleNavAnnonces"     style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Hyperlink text="Voir les animaux"    onAction="#handleNavAnimaux"      style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Hyperlink text="Réclamations"        onAction="#handleNavReclamations" style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
            </VBox>
            <VBox spacing="6" prefWidth="200">
                <Label text="Support" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="Centre d'aide" style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
                <Hyperlink text="Contactez-nous" style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Label text="FAQ" style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
            </VBox>
            <VBox spacing="6" prefWidth="200">
                <Label text="Contact" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="contact@sitmypet.com" style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
                <Label text="+216 71 000 000"      style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
            </VBox>
        </HBox>
        <HBox style="-fx-padding:10px 40px;-fx-border-color:#2d1050 transparent transparent transparent;-fx-border-width:1;">
            <Label text="© 2026 SITMYPET. Tous droits réservés." style="-fx-font-size:10px;-fx-text-fill:#888899;"/>
        </HBox>
    </VBox>

</VBox>
