<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sitmypet.controllers.AdminReclamationsOverviewController"
      maxWidth="Infinity" maxHeight="Infinity"
      spacing="16"
      style="-fx-background-color:-color-bg-surface;-fx-padding:24 28;">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label fx:id="lblPageTitle" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:-color-text-main;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="14" alignment="CENTER_RIGHT">
            <VBox spacing="4" alignment="CENTER">
                <Label fx:id="lblStatWaitLbl" style="-fx-font-size:11px;-fx-text-fill:-color-text-muted;"/>
                <Label fx:id="lblStatWait" style="-fx-font-size:18px;-fx-font-weight:bold;"/>
            </VBox>
            <VBox spacing="4" alignment="CENTER">
                <Label fx:id="lblStatCoursLbl" style="-fx-font-size:11px;-fx-text-fill:-color-text-muted;"/>
                <Label fx:id="lblStatCours" style="-fx-font-size:18px;-fx-font-weight:bold;"/>
            </VBox>
            <VBox spacing="4" alignment="CENTER">
                <Label fx:id="lblStatDoneLbl" style="-fx-font-size:11px;-fx-text-fill:-color-text-muted;"/>
                <Label fx:id="lblStatDone" style="-fx-font-size:18px;-fx-font-weight:bold;"/>
            </VBox>
        </HBox>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT"
           style="-fx-background-color:-color-bg-card;-fx-background-radius:12px;-fx-padding:14 18;-fx-border-color:-color-border;-fx-border-radius:12px;">
        <TextField fx:id="rechercheNom" prefWidth="220"/>
        <Label fx:id="lblFiltStatut"/>
        <ComboBox fx:id="filtreStatut" prefWidth="160"/>
        <Label fx:id="lblFiltPriorite"/>
        <ComboBox fx:id="filtrePriorite" prefWidth="140"/>
        <Button fx:id="btnFiltrer" onAction="#appliquerFiltre"/>
        <Button fx:id="btnReset" onAction="#reinitialiserFiltre"/>
    </HBox>

    <ScrollPane fx:id="scroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-border-color:transparent;">
        <VBox fx:id="gridCartes" spacing="14" style="-fx-padding:4 0 24 0;"/>
    </ScrollPane>
</VBox>
