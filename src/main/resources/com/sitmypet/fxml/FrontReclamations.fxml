<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sitmypet.controllers.FrontReclamationsController" stylesheets="@../css/style.css" styleClass="root">
    <top>
        <VBox spacing="10" styleClass="header">
            <Label text="✍️ Nous contacter" styleClass="title" style="-fx-font-size: 28px;"/>
            <Label text="Un problème ? Une suggestion ? N'hésitez pas à nous en faire part." styleClass="greeting-subtitle"/>
        </VBox>
    </top>
    
    <center>
        <SplitPane dividerPositions="0.4" style="-fx-background-color: transparent; -fx-padding: 20;">
            <!-- Formulaire -->
            <VBox spacing="15" styleClass="details-pane">
                <Label text="Nouvelle réclamation" styleClass="title-label" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <VBox spacing="5">
                    <Label text="Sujet" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtSujet" promptText="Ex: Problème avec une réservation" styleClass="text-field"/>
                </VBox>
                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <Label text="Description" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                    <TextArea fx:id="txtDescription" promptText="Décrivez votre problème en détail..." wrapText="true" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12; -fx-border-radius: 12;"/>
                </VBox>
                <Button text="Envoyer la réclamation" onAction="#handleEnvoyer" styleClass="btn-primary" maxWidth="Infinity">
                    <VBox.margin>
                        <Insets top="10" />
                    </VBox.margin>
                </Button>
            </VBox>
            
            <!-- Historique -->
            <VBox spacing="15" style="-fx-padding: 0 0 0 20; -fx-background-color: transparent;">
                <Label text="Mes Réclamations" styleClass="title-label" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="historiqueContainer" spacing="10" />
                </ScrollPane>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
