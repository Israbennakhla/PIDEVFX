<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sitmypet.controllers.LoginController"
            stylesheets="/style.css"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: white; -fx-padding: 0; -fx-background: white;">
    <HBox style="-fx-background-color: white;">

    <!-- PARTIE GAUCHE (Dégradé / Branding) -->
    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity" alignment="CENTER" spacing="20"
          style="-fx-background-color: linear-gradient(to bottom right, #2d1354, #8e5bd6);">
        <Label text="🐾" style="-fx-font-size: 100px; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10);"/>
        <Label text="SitMyPet" style="-fx-font-size: 48px; -fx-font-weight: 900; -fx-text-fill: white;"/>
        <Label text="Le meilleur ami de votre meilleur ami." style="-fx-font-size: 18px; -fx-text-fill: #e9d8fd;"/>
    </VBox>

    <!-- PARTIE DROITE (Formulaire de Connexion) -->
    <VBox HBox.hgrow="ALWAYS" minWidth="400" maxWidth="600" alignment="CENTER" spacing="40" style="-fx-background-color: white; -fx-padding: 60;">
        <VBox alignment="CENTER" spacing="10">
            <StackPane style="-fx-background-color: #f3e8ff; -fx-background-radius: 20; -fx-padding: 15; -fx-max-width: 60; -fx-max-height: 60;">
                <Label text="👋" style="-fx-font-size: 30px;"/>
            </StackPane>
            <Label text="Bon retour" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: #2d1354;"/>
            <Label text="Veuillez vous identifier pour continuer vers votre espace." style="-fx-text-fill: #718096; -fx-font-size: 15px; -fx-text-alignment: center;" textAlignment="CENTER" wrapText="true"/>
        </VBox>

        <VBox spacing="20" maxWidth="400">
            <!-- Email -->
            <VBox spacing="8">
                <Label text="Adresse Email" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                <TextField fx:id="txtEmail" promptText="votre.email@exemple.com" style="-fx-padding: 15; -fx-font-size: 15px; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
            </VBox>
            
            <!-- Mot de passe -->
            <VBox spacing="8">
                <Label text="Mot de Passe" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
                <PasswordField fx:id="txtPassword" promptText="••••••••" style="-fx-padding: 15; -fx-font-size: 15px; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-background-color: #f8fafc;"/>
            </VBox>
            
            <HBox alignment="CENTER_RIGHT">
                <Label text="Mot de passe oublié ?" onMouseClicked="#handleForgotPassword" style="-fx-text-fill: #8e5bd6; -fx-cursor: hand; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>


        <!-- Section CAPTCHA -->
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #f7fafc; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
            <Label text="Vérification de sécurité *" style="-fx-font-weight: 800; -fx-text-fill: #2d3748;"/>
            <HBox alignment="CENTER" spacing="15">
                <ImageView fx:id="imgCaptcha" fitHeight="50" fitWidth="160"/>
                <Button text="🔄" onAction="#genererNouveauCaptcha" style="-fx-background-color: #edf2f7; -fx-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 5 10;"/>
            </HBox>
            <TextField fx:id="txtCaptcha" promptText="Saisissez le texte de l'image" alignment="CENTER" style="-fx-padding: 10; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e0; -fx-background-color: white; -fx-pref-width: 200;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="20" maxWidth="400">
            <!-- Message d'erreur caché par défaut -->
            <Label fx:id="lblErreur" text="Email ou mot de passe incorrect." style="-fx-text-fill: #e53e3e; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-color: #fff5f5; -fx-padding: 10 20; -fx-background-radius: 8;" visible="false"/>

            <Button text="Se Connecter avec Google" onAction="#handleGoogleLogin" maxWidth="Infinity" style="-fx-background-color: white; -fx-text-fill: #4a5568; -fx-padding: 12 0; -fx-font-size: 15px; -fx-font-weight: bold; -fx-border-color: #e2e8f0; -fx-border-radius: 30; -fx-background-radius: 30; -fx-cursor: hand;"/>
            
            <HBox alignment="CENTER" spacing="10">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="OU" style="-fx-text-fill: #a0aec0; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <Button text="Se Connecter" onAction="#handleLogin" maxWidth="Infinity" style="-fx-background-color: #2d1354; -fx-text-fill: white; -fx-padding: 15 0; -fx-font-size: 18px; -fx-font-weight: 900; -fx-background-radius: 30; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45, 19, 84, 0.4), 15, 0, 0, 5);"/>
            
            <HBox alignment="CENTER" spacing="8">
                <Label text="Vous n'avez pas de compte ?" style="-fx-text-fill: #718096; -fx-font-size: 15px;"/>
                <Label text="Créer un compte" onMouseClicked="#handleGoToInscription" style="-fx-text-fill: #8e5bd6; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>
    </VBox>
    </HBox>
</ScrollPane>
