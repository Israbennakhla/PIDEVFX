<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sitmypet.controllers.EvenementController"
            stylesheets="@../css/client.css"
            prefHeight="720.0" prefWidth="1280.0">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🐾 SitMyPet" styleClass="brand-label"/>
                <Label text="ADMIN" styleClass="admin-badge"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="25">
                <Label text="💼 Dashboard" styleClass="nav-link"/>
                <Label text="📢 Annonces" styleClass="nav-link"/>
                <Label text="📅 Événements" styleClass="nav-link-active"/>
                <Label text="🐾 Animaux" styleClass="nav-link"/>
                <Label text="📩 Réclamations" styleClass="nav-link"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="👥 Inscriptions" onAction="#ouvrirParticipants"
                    styleClass="btn-participants"/>
            <Button text="🌍 Mode Client" onAction="#ouvrirClient"
                    styleClass="btn-client"/>

        </HBox>
    </top>

    <center>
        <VBox styleClass="page-content" VBox.vgrow="ALWAYS" spacing="16">

            <Label text="📅 Tous les Événements" styleClass="page-title"/>

            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12">
                
                <!-- Search & Sort Bar -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="tfSearch" promptText="🔍 Rechercher (nom, lieu)..." 
                               styleClass="text-field" HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="cbSort" promptText="Trier par" 
                              style="-fx-background-color: #F5F3FF; -fx-border-color: #DDD6FE; -fx-border-radius: 6; -fx-font-size: 13px;" />
                    <Button text="✚ Nouvel Événement" onAction="#allerVersAjout" styleClass="btn-add"/>
                </HBox>

                <!-- Event Grid (Grid View) -->
                <ScrollPane fx:id="gridScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0;">
                    <FlowPane fx:id="gridPane" hgap="20" vgap="20" style="-fx-padding: 10;" />
                </ScrollPane>

            </VBox>

        </VBox>
    </center>

</BorderPane>
