<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.sitmypet.controllers.ModifierUserController" stylesheets="/style.css" styleClass="root">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
    
    <VBox styleClass="details-pane" spacing="20" maxWidth="600">
        <!-- En-tête du formulaire -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="✎" style="-fx-font-size: 28px; -fx-text-fill: #8e5bd6;"/>
            <VBox>
                <Label text="Modifier l'utilisateur" styleClass="form-title"/>
                <Label text="Mettez à jour les informations du compte sélectionné" styleClass="note-text"/>
            </VBox>
        </HBox>
        
        <Separator styleClass="separator"/>
        
        <!-- Formulaire -->
        <GridPane hgap="15" vgap="18">
            <columnConstraints>
                <ColumnConstraints minWidth="130" prefWidth="130" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            
            <Label text="Nom *" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="txtNom" GridPane.columnIndex="1" GridPane.rowIndex="0" promptText="Nom de famille"/>
            
            <Label text="Prénom *" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="txtPrenom" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="Prénom"/>
            
            <Label text="Email *" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="exemple@domaine.com"/>
            
            <Label text="Téléphone" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="txtTelephone" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="+216 20 123 456"/>
            
            <Label text="Adresse" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="txtAdresse" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="Adresse complète"/>
            
            <Label text="Photo" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="5">
                <TextField fx:id="txtPhoto" HBox.hgrow="ALWAYS" promptText="Aucun fichier sélectionné" editable="false"/>
                <Button fx:id="btnParcourir" text="Parcourir" onAction="#handleParcourir" style="-fx-padding: 8 15;"/>
            </HBox>
            
            <Label text="Rôle *" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <ComboBox fx:id="comboRole" GridPane.columnIndex="1" GridPane.rowIndex="6" maxWidth="Infinity"/>
            
            <Label text="Statut" GridPane.columnIndex="0" GridPane.rowIndex="7" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <CheckBox fx:id="checkActif" text="Compte actif" GridPane.columnIndex="1" GridPane.rowIndex="7" style="-fx-text-fill: #4a5568;"/>
        </GridPane>
        
        <Separator styleClass="separator"/>
        
        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Label text="* Champs obligatoires" styleClass="note-text" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAnnuler" text="Annuler" onAction="#handleAnnuler" styleClass="btn-secondary"/>
            <Button fx:id="btnEnregistrer" text="Enregistrer les modifications" onAction="#handleEnregistrer" styleClass="btn-success"/>
        </HBox>
    </VBox>
</VBox>
