<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sitmypet.controllers.AfficherUserController"
            stylesheets="/style.css"
            prefHeight="750.0" prefWidth="1300.0">

    <!-- SIDEBAR GAUCHE -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260" spacing="10">
            <!-- Logo Section -->
            <VBox alignment="CENTER_LEFT" spacing="5" style="-fx-padding: 25 20 15 20;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🐾" style="-fx-font-size: 26px; -fx-text-fill: #a274db;"/>
                    <Label text="SitMyPet" styleClass="sidebar-logo-text"/>
                </HBox>
                <Label text="PANNEAU ADMIN" styleClass="sidebar-subtitle"/>
            </VBox>
            
            <Separator styleClass="sidebar-separator" />
            
            <!-- Section Principal -->
            <VBox spacing="5" style="-fx-padding: 10 15 5 15;">
                <Label text="PRINCIPAL" styleClass="sidebar-section"/>
                <Button text="⏱ Dashboard" onAction="#handleDashboard" styleClass="sidebar-btn"/>
            </VBox>
            
            <!-- Section Gestion -->
            <VBox spacing="5" style="-fx-padding: 5 15 5 15;">
                <Label text="GESTION" styleClass="sidebar-section"/>
                <Button text="👥 Utilisateurs" styleClass="sidebar-btn, sidebar-active"/>
                <Button text="🐾 Animaux" styleClass="sidebar-btn"/>
                <Button text="📢 Annonces" styleClass="sidebar-btn"/>
                <Button text="📅 Événements" styleClass="sidebar-btn"/>
                <Button text="📩 Réclamations" styleClass="sidebar-btn"/>
            </VBox>
            
            <!-- Section Publique -->
            <VBox spacing="5" style="-fx-padding: 10 15 5 15;">
                <Label text="INTERFACE PUBLIQUE" styleClass="sidebar-section"/>
                <Button text="🌐 Voir le site" styleClass="sidebar-btn"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            <Separator styleClass="sidebar-separator" />

            <!-- Utilisateur Connecté en bas -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 20 15 5 15;">
                <Label text="SA" styleClass="sidebar-avatar"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Super Admin" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="Administrateur" style="-fx-text-fill: #8a81ad; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
            
            <!-- Bouton de Déconnexion -->
            <VBox style="-fx-padding: 0 15 20 15;">
                <Button text="🚪 Se Déconnecter" onAction="#handleLogout" styleClass="sidebar-btn" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-alignment: CENTER; -fx-border-color: #3b305c; -fx-border-radius: 8; -fx-border-width: 1;"/>
            </VBox>
        </VBox>
    </left>


    <!-- CONTENU CENTRAL -->
    <center>
        <VBox>
            <!-- L'ancien En-tête -->
            <VBox styleClass="header" spacing="10">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>
                
                <VBox spacing="2">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="👋" style="-fx-font-size: 32px;"/>
                        <Label text="Bonjour, Super !" styleClass="greeting-title"/>
                    </HBox>
                    <Label text="Voici un aperçu de l'activité de SitMyPet" styleClass="greeting-subtitle"/>
                </VBox>
                
                <!-- Statistiques -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <VBox styleClass="stat-card" alignment="CENTER" spacing="5">
                        <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>
                        <Label text="Total utilisateurs" styleClass="stat-label"/>
                        <Label fx:id="lblTotal" text="0" styleClass="stat-value"/>
                    </VBox>
                    <VBox styleClass="stat-card admin" alignment="CENTER" spacing="5">
                        <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>
                        <Label text="Administrateurs" styleClass="stat-label"/>
                        <Label fx:id="lblAdmin" text="0" styleClass="stat-value"/>
                    </VBox>
                    <VBox styleClass="stat-card proprietaire" alignment="CENTER" spacing="5">
                        <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>
                        <Label text="Propriétaires" styleClass="stat-label"/>
                        <Label fx:id="lblProprietaire" text="0" styleClass="stat-value"/>
                    </VBox>
                    <VBox styleClass="stat-card gardien" alignment="CENTER" spacing="5">
                        <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>
                        <Label text="Gardiens" styleClass="stat-label"/>
                        <Label fx:id="lblGardien" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Section Liste & Recherche -->
            <VBox spacing="15" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>
                
                <!-- Barre de recherche -->
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="search-bar">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="Rechercher:" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;" minWidth="-Infinity"/>
                    <TextField fx:id="txtRecherche" promptText="Nom ou prénom..." HBox.hgrow="ALWAYS" prefWidth="180"/>
                    
                    <Label text="Rôle:" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;" minWidth="-Infinity"/>
                    <ComboBox fx:id="comboRole" prefWidth="110" minWidth="-Infinity"/>
                    
                    <Label text="Statut:" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;" minWidth="-Infinity"/>
                    <ComboBox fx:id="comboStatut" prefWidth="100" minWidth="-Infinity"/>
                    
                    <Label text="Tri:" style="-fx-font-weight: bold; -fx-text-fill: #2d3748;" minWidth="-Infinity"/>
                    <ComboBox fx:id="comboTri" prefWidth="120" minWidth="-Infinity"/>
                    
                    <Button text="Rechercher" onAction="#handleRechercher" styleClass="btn-primary" style="-fx-padding: 8 15; -fx-font-size: 13px;" minWidth="-Infinity"/>
                    <Button text="Reset" onAction="#handleReinitialiser" styleClass="btn-secondary" style="-fx-padding: 8 15; -fx-font-size: 13px;" minWidth="-Infinity"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Ajouter" onAction="#handleAjouter" styleClass="btn-success" style="-fx-padding: 8 20; -fx-font-size: 14px;" minWidth="-Infinity"/>
                </HBox>
                
                <!-- Conteneur Principal ListView + Menu Détails -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <!-- Liste remplaçant le tableau -->
                    <ListView fx:id="listUsers" styleClass="custom-list-view" HBox.hgrow="ALWAYS" prefWidth="650"/>
                    
                    <!-- Panneau de détails caché par défaut -->
                    <VBox fx:id="paneDetails" styleClass="details-pane" prefWidth="320" spacing="15" visible="false" managed="false">
                        <Label text="Détails Utilisateur" styleClass="title-label">
                            <font><Font name="System Bold" size="18"/></font>
                        </Label>
                        <Separator/>
                        
                        <HBox alignment="CENTER">
                            <Label fx:id="lblDetailInitials" alignment="CENTER" prefHeight="80" prefWidth="80" styleClass="avatar-placeholder"/>
                        </HBox>
                        <Label fx:id="lblDetailNom" style="-fx-font-size: 20px; -fx-font-weight: bold;" alignment="CENTER" maxWidth="Infinity"/>
                        
                        <GridPane hgap="10" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints minWidth="80" prefWidth="80"/>
                                <ColumnConstraints hgrow="ALWAYS" prefWidth="180" maxWidth="180"/>
                            </columnConstraints>
                            
                            <Label text="ID :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailId" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            
                            <Label text="Email :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailEmail" GridPane.columnIndex="1" GridPane.rowIndex="1" wrapText="true"/>
                            
                            <Label text="Téléphone :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailTel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            
                            <Label text="Adresse :" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailAdresse" GridPane.columnIndex="1" GridPane.rowIndex="3" wrapText="true"/>
                            
                            <Label text="Rôle :" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailRole" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            
                            <Label text="Statut :" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailStatut" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                            
                            <Label text="Inscrit le :" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailDate" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                        </GridPane>
                    </VBox>
                </HBox>
                
            </VBox>
        </VBox>
    </center>
</BorderPane>
