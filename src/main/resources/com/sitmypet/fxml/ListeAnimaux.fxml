<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sitmypet.controllers.ListeAnimauxController"
      prefWidth="1100" prefHeight="700"
      spacing="16"
      style="-fx-background-color:#f0f0f8;-fx-padding:24 28;">

    <HBox alignment="CENTER_LEFT">
        <Label text="🐾 Mes animaux" style="-fx-font-size:24px;-fx-font-weight:bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Ajouter un animal" onAction="#handleAjouter"
                style="-fx-background-color:#9b72e8;-fx-text-fill:white;-fx-padding:10 20;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color:white;-fx-background-radius:10px;-fx-padding:14px 18px;">
        <TextField fx:id="searchNom" promptText="Rechercher par nom" prefWidth="200"/>
        <ComboBox fx:id="filterType" prefWidth="130"/>
        <ComboBox fx:id="filterGenre" prefWidth="120"/>
        <ComboBox fx:id="filterVaccine" prefWidth="120"/>
        <ComboBox fx:id="filterCritique" prefWidth="120"/>
        <Button text="Rechercher" onAction="#handleRechercher"/>
        <Button text="Réinitialiser" onAction="#handleReinitialiser"/>
    </HBox>

    <ListView fx:id="listAnimaux" VBox.vgrow="ALWAYS"/>

    <HBox alignment="CENTER" spacing="8" style="-fx-background-color:white;-fx-padding:10 20;">
        <Label fx:id="labelPagination"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnPrev" text="Préc." onAction="#handlePrevPage"/>
        <HBox fx:id="pageButtons" spacing="4"/>
        <Button fx:id="btnNext" text="Suiv." onAction="#handleNextPage"/>
        <Label text="Par page :"/>
        <ComboBox fx:id="comboPerPage" prefWidth="70"/>
    </HBox>
</VBox>
