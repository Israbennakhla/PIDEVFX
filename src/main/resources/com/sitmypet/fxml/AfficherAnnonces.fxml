<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sitmypet.controllers.AfficherAnnoncesController"
      styleClass="root" stylesheets="@../css/style.css"
      style="-fx-background-color: transparent;">

    <!-- CONTENU -->
    <VBox VBox.vgrow="ALWAYS" spacing="16" style="-fx-padding: 25px 30px;">

        <HBox alignment="CENTER_LEFT" styleClass="header" style="-fx-background-color: transparent; -fx-padding: 0;">
            <Label text="Mes Annonces" styleClass="title" style="-fx-font-size: 22px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Nouvelle annonce" onAction="#handleNouvelle" styleClass="btn-primary" style="-fx-font-size: 13px; -fx-padding: 10 20;"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="details-pane" style="-fx-padding: 14px 18px;">
            <TextField fx:id="searchAdresse" promptText="Rechercher par adresse" prefWidth="220" styleClass="text-field"/>
            <DatePicker fx:id="filterDateDebut" promptText="Date début" prefWidth="150" styleClass="text-field"/>
            <DatePicker fx:id="filterDateFin"   promptText="Date fin"   prefWidth="150" styleClass="text-field"/>
            <Button text="Rechercher" onAction="#handleRechercher" styleClass="btn-success" style="-fx-font-size: 13px; -fx-padding: 8 18;"/>
            <Button text="Réinitialiser" onAction="#handleReinitialiser" styleClass="btn-secondary" style="-fx-font-size: 13px; -fx-padding: 8 18;"/>
        </HBox>

        <ListView fx:id="listAnnonces" VBox.vgrow="ALWAYS" styleClass="custom-list-view" style="-fx-background-color: transparent;"/>

        <HBox alignment="CENTER" spacing="8" styleClass="details-pane" style="-fx-padding: 10px 20px;">
            <Label fx:id="labelPagination" style="-fx-font-size: 12px; -fx-text-fill: -color-text-muted;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnPrev" text="Préc." onAction="#handlePrevPage" styleClass="btn-secondary" style="-fx-font-size: 12px; -fx-padding: 6 14;"/>
            <HBox fx:id="pageButtons" spacing="4" alignment="CENTER"/>
            <Button fx:id="btnNext" text="Suiv." onAction="#handleNextPage" styleClass="btn-secondary" style="-fx-font-size: 12px; -fx-padding: 6 14;"/>
            <Region style="-fx-min-width: 20;"/>
            <Label text="Par page :" style="-fx-font-size: 12px; -fx-text-fill: -color-text-muted;"/>
            <ComboBox fx:id="comboPerPage" prefWidth="70" styleClass="combo-box" style="-fx-font-size: 12px;"/>
        </HBox>
    </VBox>
</VBox>
