<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sitmypet.controllers.FrontAnimauxController" stylesheets="@../css/style.css" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header" spacing="20">
            <Label text="🐾 Mes Compagnons" styleClass="title" style="-fx-font-size: 28px;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="+ Ajouter un compagnon" onAction="#handleShowForm" styleClass="btn-primary" style="-fx-font-size: 16px; -fx-padding: 10 20; -fx-background-radius: 20;"/>
        </HBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 20;">
            <TilePane fx:id="cardsContainer" hgap="20" vgap="20" prefColumns="3" alignment="TOP_LEFT" />
        </ScrollPane>
    </center>
    
    <right>
        <VBox fx:id="formContainer" managed="false" visible="false" spacing="15" styleClass="details-pane" prefWidth="350">
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblFormTitle" text="Nouveau compagnon" styleClass="title-label" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✕" onAction="#handleCloseForm" style="-fx-background-color: transparent; -fx-text-fill: -color-text-muted; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
            
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="15" style="-fx-padding: 5;">
                    <VBox spacing="5">
                        <Label text="Nom" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                        <TextField fx:id="txtNom" styleClass="text-field"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Type" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="cbType" maxWidth="Infinity" styleClass="combo-box"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Race" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                        <TextField fx:id="txtRace" styleClass="text-field"/>
                    </VBox>
                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Genre" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="cbGenre" maxWidth="Infinity" styleClass="combo-box"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Poids (kg)" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                            <TextField fx:id="txtPoids" styleClass="text-field"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="5">
                        <Label text="Date de naissance" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                        <DatePicker fx:id="dpNaissance" maxWidth="Infinity" styleClass="text-field"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Description" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold;"/>
                        <TextArea fx:id="txtDescription" prefRowCount="3" style="-fx-background-radius: 12; -fx-border-radius: 12;" wrapText="true"/>
                    </VBox>
                    
                    <Label text="État de santé" style="-fx-text-fill: -color-text-secondary; -fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
                    <CheckBox fx:id="chkVaccine" text="Vacciné" style="-fx-text-fill: -color-text-secondary;"/>
                    <CheckBox fx:id="chkDossier" text="Possède un carnet de santé" style="-fx-text-fill: -color-text-secondary;"/>
                    <CheckBox fx:id="chkMaladie" text="Maladie contagieuse" style="-fx-text-fill: -color-text-danger;"/>
                    <CheckBox fx:id="chkCritique" text="Condition médicale critique" style="-fx-text-fill: -color-text-danger;"/>
                </VBox>
            </ScrollPane>
            
            <Button fx:id="btnSubmit" text="Enregistrer" onAction="#handleSubmit" styleClass="btn-success" maxWidth="Infinity">
                <VBox.margin>
                    <Insets top="10" />
                </VBox.margin>
            </Button>
        </VBox>
    </right>
</BorderPane>
