<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.EventDetailOverlayController"
           prefWidth="580" prefHeight="720"
           style="-fx-background-color: transparent;">

    <!-- Dark themed card (matching TicketDialog style) -->
    <VBox alignment="TOP_CENTER" spacing="0"
          style="-fx-background-color: #0a0a1a; -fx-background-radius: 24;">

        <!-- ── HEADER ────────────────────────────────────────────────── -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);
                     -fx-background-radius: 24 24 0 0; -fx-padding: 32 30 24 30;">
            <Label text="📅" style="-fx-font-size: 42px;"/>
            <Label text="DÉTAILS DE L'ÉVÉNEMENT"
                   style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);
                          -fx-letter-spacing: 3; -fx-font-weight: bold;"/>
            <Label fx:id="lblEventName"
                   style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;
                          -fx-wrap-text: true; -fx-text-alignment: center;"
                   maxWidth="500" wrapText="true"/>
        </VBox>

        <!-- ── TEAR EDGE ─────────────────────────────────────────────── -->
        <HBox style="-fx-background-color: #0f1923; -fx-padding: 0;" alignment="CENTER">
            <Label style="-fx-font-size: 22px; -fx-text-fill: #0a0a1a;"
                   text="◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦"/>
        </HBox>

        <!-- ── BODY ──────────────────────────────────────────────────── -->
        <VBox VBox.vgrow="ALWAYS" spacing="14"
              style="-fx-background-color: #111827; -fx-padding: 20 32;">

            <!-- Info rows -->
            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="130"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <!-- Date -->
                <Label text="📅  Date" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill: #7c8db5; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="lblDate" GridPane.rowIndex="0" GridPane.columnIndex="1"
                       style="-fx-text-fill: white; -fx-font-size: 14px;" wrapText="true"/>

                <!-- Heure -->
                <Label text="🕐  Heure" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill: #7c8db5; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="lblHeure" GridPane.rowIndex="1" GridPane.columnIndex="1"
                       style="-fx-text-fill: white; -fx-font-size: 14px;"/>

                <!-- Adresse -->
                <Label text="📍  Adresse" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill: #7c8db5; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="lblAddress" GridPane.rowIndex="2" GridPane.columnIndex="1"
                       style="-fx-text-fill: white; -fx-font-size: 14px;" wrapText="true"/>

                <!-- Description -->
                <Label text="📝  Description" GridPane.rowIndex="3" GridPane.columnIndex="0"
                       style="-fx-text-fill: #7c8db5; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="lblDescription" GridPane.rowIndex="3" GridPane.columnIndex="1"
                       style="-fx-text-fill: #a0aec0; -fx-font-size: 13px;" wrapText="true"
                       maxHeight="80"/>
            </GridPane>

            <!-- Dashed separator -->
            <HBox alignment="CENTER" style="-fx-padding: 4 0;">
                <Label text="- - - - - - - - - - LOCALISATION - - - - - - - - - -"
                       style="-fx-text-fill: #4a5568; -fx-font-size: 11px; -fx-letter-spacing: 1;"/>
            </HBox>

            <!-- Map WebView -->
            <VBox VBox.vgrow="ALWAYS" alignment="CENTER"
                  style="-fx-background-color: #1e2d4a; -fx-background-radius: 12; -fx-padding: 8;">
                <WebView fx:id="mapWebView" prefHeight="220" VBox.vgrow="ALWAYS"/>
            </VBox>
        </VBox>

        <!-- ── TEAR EDGE (bottom) ─────────────────────────────────────── -->
        <HBox style="-fx-background-color: #0f1923; -fx-padding: 0;" alignment="CENTER">
            <Label style="-fx-font-size: 22px; -fx-text-fill: #0a0a1a;"
                   text="◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦ ◦"/>
        </HBox>

        <!-- ── FOOTER ─────────────────────────────────────────────────── -->
        <HBox alignment="CENTER" spacing="12"
              style="-fx-background-color: #0f1923; -fx-background-radius: 0 0 24 24; -fx-padding: 14 30;">
            <Button text="✖  Fermer" onAction="#fermer"
                    style="-fx-background-color: #374151; -fx-text-fill: white; -fx-font-size: 13px;
                           -fx-background-radius: 10; -fx-padding: 10 28; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</StackPane>
