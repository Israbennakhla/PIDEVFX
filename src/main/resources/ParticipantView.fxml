<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ParticipantController"
            stylesheets="@client.css"
            prefHeight="720.0" prefWidth="1280.0">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🐾 SitMyPet" styleClass="brand-label"/>
                <Label text="ADMIN" styleClass="admin-badge"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="25">
                <Label text="💼 Dashboard" styleClass="nav-link"/>
                <Label text="📢 Annonces" styleClass="nav-link"/>
                <Label text="📅 Événements" styleClass="nav-link-active"/>
                <Label text="🐾 Animaux" styleClass="nav-link"/>
                <Label text="📩 Réclamations" styleClass="nav-link"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⬅️ Retour" onAction="#retourEvenements" styleClass="btn-client"/>
        </HBox>
    </top>

    <left>
        <VBox style="-fx-padding: 24 16;" spacing="0">
            <VBox styleClass="form-card">
                <Label text="📝 Gestion d'Inscription" styleClass="form-title"/>
                <TextField fx:id="tfEventId" promptText="ID de l'Événement" styleClass="text-field"/>
                <TextField fx:id="tfUserId"  promptText="ID de l'Utilisateur" styleClass="text-field"/>
                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 6 0 0 0;">
                    <Button text="✚ Inscrire (Ajouter)" onAction="#ajouterParticipant" styleClass="btn-add" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="page-content" spacing="16">
            <Label text="👥 Tableau des Participants" styleClass="page-title"/>
            
            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12">
                
                <VBox spacing="8">
                    <TextField fx:id="tfSearch" promptText="🔍 Rechercher par nom d'utilisateur ou événement..." 
                               styleClass="text-field" />
                    <!-- Filter and Sort Combo Boxes -->
                    <HBox spacing="10">
                        <ComboBox fx:id="cbFilterEvent" promptText="Filtrer par événement" 
                                  style="-fx-background-color: #F5F3FF; -fx-border-color: #DDD6FE; -fx-border-radius: 6; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ComboBox fx:id="cbSort" promptText="Trier par" 
                                  style="-fx-background-color: #F5F3FF; -fx-border-color: #DDD6FE; -fx-border-radius: 6; -fx-font-size: 13px;" />
                    </HBox>
                </VBox>

                <ListView fx:id="listParticipants" styleClass="admin-list" VBox.vgrow="ALWAYS" />
                
                <HBox alignment="CENTER_RIGHT">
                    <Button text="🗑 Désinscrire (Supprimer)" onAction="#supprimerParticipant" styleClass="btn-delete" />
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
