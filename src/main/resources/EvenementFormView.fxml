<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.EvenementFormController"
           stylesheets="@client.css"
           prefWidth="740" prefHeight="560"
           style="-fx-background-color: transparent;">

    <!-- Light themed card (matching app palette) -->
    <VBox alignment="TOP_CENTER" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 18;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.20), 24, 0, 0, 6);">

        <!-- ── HEADER (purple gradient) ──────────────────────────────── -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-background-color: linear-gradient(to right, #6C3CE1, #7C3AED, #8B5CF6);
                     -fx-background-radius: 18 18 0 0; -fx-padding: 20 30 16 30;">
            <Label fx:id="lblTitle" text="📋 Formulaire Événement"
                   style="-fx-font-size: 20px; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label text="Remplissez les informations et sélectionnez l'emplacement sur la carte"
                   style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
        </VBox>

        <!-- ── BODY: Form + Map side by side ─────────────────────────── -->
        <HBox VBox.vgrow="ALWAYS" spacing="20"
              style="-fx-background-color: #F5F3FF; -fx-padding: 20 24;">

            <!-- LEFT: Form Fields -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-min-width: 280;">

                <TextField fx:id="tfName" promptText="Nom de l'événement"
                           styleClass="text-field"/>

                <DatePicker fx:id="dpDate" promptText="Date" maxWidth="Infinity"/>

                <TextField fx:id="tfHeure" promptText="Heure  (ex: 14:30)"
                           styleClass="text-field"/>

                <TextField fx:id="tfAddresse" promptText="📍 Adresse (ou cliquez sur la carte)"
                           style="-fx-background-color: #F5F3FF; -fx-border-color: #6C3CE1;
                                  -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 10;
                                  -fx-font-size: 13px; -fx-text-fill: #1A1A2E;"/>

                <TextField fx:id="tfDescription" promptText="Description"
                           styleClass="text-field"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox spacing="10" alignment="CENTER">
                    <Button text="✔ Enregistrer" onAction="#enregistrerEvenement"
                            styleClass="btn-add" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="✖ Annuler" onAction="#retourListe"
                            styleClass="btn-clear" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

            <!-- RIGHT: Interactive Map -->
            <VBox HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_CENTER"
                  style="-fx-min-width: 300;">
                <Label text="🗺️ Cliquez pour choisir l'emplacement"
                       style="-fx-text-fill: #6C3CE1; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #EDE9FF; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 4;">
                    <WebView fx:id="adminMapWebView" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>

        </HBox>

        <!-- ── FOOTER ─────────────────────────────────────────────────── -->
        <HBox alignment="CENTER"
              style="-fx-background-color: #EEF0FA; -fx-background-radius: 0 0 18 18; -fx-padding: 10 24;">
            <Label text="🐾 SitMyPet — Gestion des événements"
                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;"/>
        </HBox>
    </VBox>
</StackPane>
