<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EvenementFormController"
            stylesheets="@client.css"
            prefHeight="720.0" prefWidth="1280.0">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🐾 SitMyPet" styleClass="brand-label"/>
                <Label text="ADMIN" styleClass="admin-badge"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="25">
                <Label text="💼 Dashboard" styleClass="nav-link"/>
                <Label text="📢 Annonces" styleClass="nav-link"/>
                <Label text="📅 Événements" styleClass="nav-link-active"/>
                <Label text="🐾 Animaux" styleClass="nav-link"/>
                <Label text="📩 Réclamations" styleClass="nav-link"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="👥 Inscriptions" onAction="#ouvrirParticipants"
                    styleClass="btn-participants"/>
            <Button text="🌍 Mode Client" onAction="#ouvrirClient"
                    styleClass="btn-client"/>

        </HBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="30" style="-fx-padding: 30 40;">

            <!-- ── LEFT: Form Card ──────────────────────────────────────── -->
            <VBox styleClass="form-card" maxWidth="500" alignment="CENTER" spacing="15"
                  VBox.vgrow="NEVER" HBox.hgrow="NEVER"
                  style="-fx-max-width: 500; -fx-min-width: 400;">

                <Label fx:id="lblTitle" text="📋 Formulaire Événement" styleClass="form-title"/>

                <TextField fx:id="tfName"        promptText="Nom de l'événement"   styleClass="text-field"/>
                <DatePicker fx:id="dpDate"        promptText="Date"                 maxWidth="Infinity"/>
                <TextField fx:id="tfHeure"        promptText="Heure  (ex: 14:30)"   styleClass="text-field"/>
                <TextField fx:id="tfAddresse"     promptText="Adresse (ex: Tunis)"  styleClass="text-field"/>
                <TextField fx:id="tfDescription"  promptText="Description"           styleClass="text-field"/>

                <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                    <Button text="✔ Enregistrer"  onAction="#enregistrerEvenement"  styleClass="btn-add"  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="🔙 Annuler" onAction="#retourListe" styleClass="btn-clear" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>

            </VBox>

            <!-- ── RIGHT: Interactive Map ───────────────────────────────── -->
            <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="TOP_CENTER"
                  style="-fx-padding: 0;">

                <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10"
                      style="-fx-min-width: 420;">

                    <Label text="🗺️ Sélectionner la localisation" styleClass="form-title"/>
                    <Label text="Cliquez sur la carte pour choisir l'adresse"
                           style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>

                    <WebView fx:id="adminMapWebView" VBox.vgrow="ALWAYS" prefHeight="400"/>

                </VBox>
            </VBox>

        </HBox>
    </center>

</BorderPane>
