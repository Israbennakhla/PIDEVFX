<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ClientController"
            stylesheets="@client.css"
            prefHeight="720.0" prefWidth="1280.0">

    <!-- ── TOP NAV BAR ─────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="20">

            <Label text="🐾 SitMyPet" styleClass="brand-label"/>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="25">
                <Label text="💼 Dashboard" styleClass="nav-link"/>
                <Label text="📢 Annonces" styleClass="nav-link"/>
                <Label text="📅 Événements" styleClass="nav-link-active"/>
                <Label text="🐾 Animaux" styleClass="nav-link"/>
                <Label text="📩 Réclamations" styleClass="nav-link"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <ComboBox fx:id="cbMockUser" onAction="#onUserChanged"/>
            <Button text="🔑 Admin" onAction="#retourAdmin" styleClass="btn-admin"/>

        </HBox>
    </top>

    <!-- ── MAIN CONTENT ─────────────────────────────────────────────────── -->
    <center>
        <VBox styleClass="page-content" VBox.vgrow="ALWAYS">
            <VBox styleClass="card" VBox.vgrow="ALWAYS">

                <!-- Header + Search Bar + Toggle -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="🌐 Tous les Événements" styleClass="page-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnToggleView" text="🔲" onAction="#toggleView" styleClass="btn-client" style="-fx-font-size: 16px; -fx-padding: 4 10;"/>
                    <TextField fx:id="tfSearch" promptText="🔍 Rechercher (nom, lieu)..." 
                               styleClass="text-field" prefWidth="280" />
                </HBox>

                <StackPane VBox.vgrow="ALWAYS">
                    <!-- Event table (List View) with Taller spacing -->
                    <TableView fx:id="tableEvenements" style="-fx-fixed-cell-size: 50px;">
                        <columns>
                            <TableColumn fx:id="colNom"         text="Nom"          prefWidth="130"/>
                            <TableColumn fx:id="colDate"        text="Date"         prefWidth="110"/>
                            <TableColumn fx:id="colHeure"       text="Heure"        prefWidth="80"/>
                            <TableColumn fx:id="colAdresse"     text="Adresse"      prefWidth="110"/>
                            <TableColumn fx:id="colDescription" text="Description"  prefWidth="160"/>
                            <TableColumn fx:id="colParticipation" text="Participation" prefWidth="110"/>
                            <TableColumn fx:id="colActions"     text="Actions"      prefWidth="130"/>
                        </columns>
                    </TableView>
                    
                    <!-- Event Grid (Grid View) -->
                    <ScrollPane fx:id="gridScrollPane" visible="false" fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0;">
                        <FlowPane fx:id="gridPane" hgap="20" vgap="20" style="-fx-padding: 10;" />
                    </ScrollPane>
                </StackPane>

            </VBox>
        </VBox>
    </center>

</BorderPane>
