<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EvenementController"
            stylesheets="@client.css"
            prefHeight="720.0" prefWidth="1280.0">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🐾 SitMyPet" styleClass="brand-label"/>
                <Label text="ADMIN" styleClass="admin-badge"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="25">
                <Label text="💼 Dashboard" styleClass="nav-link"/>
                <Label text="📢 Annonces" styleClass="nav-link"/>
                <Label text="📅 Événements" styleClass="nav-link-active"/>
                <Label text="🐾 Animaux" styleClass="nav-link"/>
                <Label text="📩 Réclamations" styleClass="nav-link"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="👥 Inscriptions" onAction="#ouvrirParticipants"
                    styleClass="btn-participants"/>
            <Button text="🌍 Mode Client" onAction="#ouvrirClient"
                    styleClass="btn-client"/>

        </HBox>
    </top>

    <left>
        <VBox style="-fx-padding: 24 16;" spacing="0">
            <VBox styleClass="form-card">

                <Label text="📋 Formulaire Événement" styleClass="form-title"/>

                <TextField fx:id="tfName"        promptText="Nom de l'événement"   styleClass="text-field"/>
                <DatePicker fx:id="dpDate"        promptText="Date"                 maxWidth="Infinity"/>
                <TextField fx:id="tfHeure"        promptText="Heure  (ex: 14:30)"   styleClass="text-field"/>
                <TextField fx:id="tfAddresse"     promptText="Adresse (ex: Tunis)"  styleClass="text-field"/>
                <TextField fx:id="tfDescription"  promptText="Description"           styleClass="text-field"/>

                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 6 0 0 0;">
                    <Button text="✚ Ajouter"  onAction="#ajouterEvenement"  styleClass="btn-add"  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="✎ Modifier" onAction="#modifierEvenement" styleClass="btn-edit" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>

                <Button text="↺ Vider le formulaire" onAction="#viderFormulaire"
                        styleClass="btn-clear" maxWidth="Infinity"/>

            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="page-content" spacing="16">

            <Label text="📅 Liste des Événements" styleClass="page-title"/>

            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12">
                
                <!-- Search & Sort Bar -->
                <HBox spacing="10">
                    <TextField fx:id="tfSearch" promptText="🔍 Rechercher (nom, lieu)..." 
                               styleClass="text-field" HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="cbSort" promptText="Trier par" 
                              style="-fx-background-color: #F5F3FF; -fx-border-color: #DDD6FE; -fx-border-radius: 6; -fx-font-size: 13px;" />
                </HBox>

                <ListView fx:id="listEvenements"
                          onMouseClicked="#remplirFormulaire"
                          styleClass="admin-list"
                          VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT">
                    <Button text="🗑 Supprimer l'événement" onAction="#supprimerEvenement"
                            styleClass="btn-delete"/>
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>