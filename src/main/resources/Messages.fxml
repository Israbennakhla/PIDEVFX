<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.MessageriePropController"
      prefWidth="1280" prefHeight="760"
      style="-fx-background-color:#f0f0f8;">

    <!-- NAVBAR -->
    <HBox fx:id="navbarHBox" alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color:#1a0a2e;-fx-padding:0 30px;-fx-min-height:64px;-fx-max-height:64px;">
        <VBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding:0 30 0 0;">
            <Label text="SitMyPet" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:white;"/>
        </VBox>
        <Button text="Dashboard"    onAction="#handleNavDashboard"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Accueil"      onAction="#handleNavAccueil"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Postulations" onAction="#handleNavPostulations"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Annonces"     onAction="#handleNavAnnonces"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Evenements"   onAction="#handleNavEvenements"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Animaux"      onAction="#handleNavAnimaux"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <!-- Messagerie actif -->
        <Button text="Messagerie"   onAction="#handleNavMessagerie"
                style="-fx-background-color:transparent;-fx-text-fill:#f5c518;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="Reclamations" onAction="#handleNavReclamations"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="👤" style="-fx-background-color:#c084fc;-fx-text-fill:white;-fx-background-radius:50%;-fx-font-size:14px;-fx-cursor:hand;-fx-padding:8 10;-fx-min-width:36;"/>
    </HBox>

    <!-- CONTENU : 2 colonnes -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- Colonne gauche : liste conversations -->
        <VBox prefWidth="300" minWidth="280" maxWidth="320"
              style="-fx-background-color:white;-fx-border-color:#e8e0f5 transparent transparent transparent;-fx-border-width:0 1 0 0;">

            <HBox style="-fx-background-color:#f8f5ff;-fx-padding:16 18;
                         -fx-border-color:transparent transparent #e8e0f5 transparent;-fx-border-width:0 0 1 0;">
                <Label text="Conversations"
                       style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a1a2e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelNbConv"
                       style="-fx-font-size:12px;-fx-text-fill:#9b72e8;-fx-font-weight:bold;"/>
            </HBox>

            <ListView fx:id="listConversations" VBox.vgrow="ALWAYS"
                      style="-fx-background-color:transparent;-fx-border-color:transparent;
                             -fx-focus-color:transparent;-fx-faint-focus-color:transparent;"/>
        </VBox>

        <!-- Colonne droite : chat -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color:#f0f0f8;">

            <!-- En-tête chat -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color:white;-fx-padding:14 20;
                         -fx-border-color:#e8e0f5 transparent #e8e0f5 transparent;
                         -fx-border-width:1 0 1 0;-fx-min-height:60;-fx-max-height:60;">
                <Label fx:id="labelInterlocuteur" text="Selectionnez une conversation"
                       style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a1a2e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelStatut" text=""
                       style="-fx-font-size:11px;-fx-text-fill:#4caf50;-fx-font-weight:bold;"/>
            </HBox>

            <!-- Messages -->
            <ScrollPane fx:id="scrollMessages" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:#f0f0f8;-fx-border-color:transparent;
                               -fx-focus-color:transparent;">
                <VBox fx:id="messagesBox" spacing="10"
                      style="-fx-background-color:#f0f0f8;-fx-padding:16;"/>
            </ScrollPane>

            <!-- Saisie -->
            <HBox spacing="0" alignment="CENTER"
                  style="-fx-background-color:white;
                         -fx-border-color:#e8e0f5 transparent transparent transparent;
                         -fx-border-width:1 0 0 0;-fx-min-height:70;-fx-max-height:70;">
                <TextArea fx:id="inputField"
                          promptText="Repondez au gardien... (Entree pour envoyer)"
                          prefRowCount="2" wrapText="true"
                          style="-fx-background-color:transparent;-fx-border-color:transparent;
                                 -fx-font-size:13px;-fx-padding:12 16;"/>
                <HBox.hgrow><Priority fx:constant="ALWAYS"/></HBox.hgrow>
                <Button fx:id="btnEnvoyer" text="Envoyer" onAction="#handleEnvoyer"
                        style="-fx-background-color:#9b72e8;-fx-text-fill:white;
                               -fx-font-size:13px;-fx-font-weight:bold;
                               -fx-background-radius:0;-fx-cursor:hand;
                               -fx-padding:0 24;-fx-min-height:70;-fx-max-height:70;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
