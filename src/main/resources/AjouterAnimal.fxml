<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AjouterAnimalController"
      prefWidth="900" prefHeight="800"
      style="-fx-background-color: #f5f5f5;">

    <!-- ===================== NAVBAR ===================== -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #1a0a2e; -fx-padding: 0 30px;
                 -fx-min-height: 64px; -fx-max-height: 64px;">
        <VBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding: 0 30 0 0;">
            <Label text="🐾🐾" style="-fx-font-size: 20px;"/>
            <Label text="SitMyPet" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
        <Button text="🏠 Dashboard" onAction="#handleNavDashboard"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="📣 Annonces" onAction="#handleNavAnnonces"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="📅 Événements" onAction="#handleNavEvenements"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <!-- Animaux actif -->
        <Button text="🐾 Animaux" onAction="#handleNavAnimaux"
                style="-fx-background-color:transparent;-fx-text-fill:#f5c518;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Button text="📩 Réclamations" onAction="#handleNavReclamations"
                style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔔" style="-fx-background-color:#2d1050;-fx-text-fill:white;-fx-background-radius:50%;-fx-font-size:14px;-fx-cursor:hand;-fx-padding:8 10;-fx-min-width:36;"/>
        <Region style="-fx-min-width:8;"/>
        <Button text="🌙" style="-fx-background-color:#2d1050;-fx-text-fill:white;-fx-background-radius:50%;-fx-font-size:14px;-fx-cursor:hand;-fx-padding:8 10;-fx-min-width:36;"/>
        <Region style="-fx-min-width:8;"/>
        <Button text="👤" style="-fx-background-color:#c084fc;-fx-text-fill:white;-fx-background-radius:50%;-fx-font-size:14px;-fx-cursor:hand;-fx-padding:8 10;-fx-min-width:36;"/>
    </HBox>

    <!-- ===================== CONTENU ===================== -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="20" style="-fx-background-color: #f5f5f5;">
            <padding><Insets top="20" right="60" bottom="20" left="60"/></padding>

            <!-- En-tête -->
            <HBox alignment="CENTER_LEFT">
                <Label text="🐾 Ajouter un animal"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink text="← Retour" fx:id="btnRetour" onAction="#handleRetour"
                           style="-fx-font-size: 13px; -fx-text-fill: #7c5cbf;"/>
            </HBox>

            <!-- Zone photo + nom -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: #c9b8f0; -fx-background-radius: 16px; -fx-padding: 20px;">
                <Button fx:id="btnPhoto" text="📷" onAction="#handlePhotoUpload"
                        prefWidth="70" prefHeight="70"
                        style="-fx-background-color: white; -fx-background-radius: 50%;
                               -fx-font-size: 22px; -fx-cursor: hand;"/>
                <TextField fx:id="nomAnimal" promptText="Nom de l'animal" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: transparent;
                                  -fx-border-color: transparent transparent white transparent;
                                  -fx-border-width: 1.5px; -fx-font-size: 16px;
                                  -fx-text-fill: white; -fx-prompt-text-fill: #ffffffcc;"/>
            </HBox>

            <!-- Formulaire -->
            <GridPane hgap="30" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Race" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                    <TextField fx:id="race"
                               style="-fx-background-color: white; -fx-border-color: #cccccc;
                                      -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 6px 10px;"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Type d'animal" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    <fx:define><ToggleGroup fx:id="typeAnimalGroup"/></fx:define>
                    <FlowPane hgap="8" vgap="8">
                        <RadioButton text="CHAT"    toggleGroup="$typeAnimalGroup" userData="CHAT"    style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 12;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                        <RadioButton text="CHIEN"   toggleGroup="$typeAnimalGroup" userData="CHIEN"   style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 12;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                        <RadioButton text="TORTUE"  toggleGroup="$typeAnimalGroup" userData="TORTUE"  style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 12;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                        <RadioButton text="LAPIN"   toggleGroup="$typeAnimalGroup" userData="LAPIN"   style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 12;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                        <RadioButton text="OISEAU"  toggleGroup="$typeAnimalGroup" userData="OISEAU"  style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 12;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                        <RadioButton text="POISSON" toggleGroup="$typeAnimalGroup" userData="POISSON" style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 12;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                        <RadioButton text="SOURIS"  toggleGroup="$typeAnimalGroup" userData="SOURIS"  style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 12;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                    </FlowPane>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Poids (kg)" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                    <TextField fx:id="poids"
                               style="-fx-background-color: white; -fx-border-color: #cccccc;
                                      -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 6px 10px;"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Genre" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    <fx:define><ToggleGroup fx:id="genreGroup"/></fx:define>
                    <HBox spacing="15">
                        <RadioButton fx:id="radioMale"   text="MALE"   toggleGroup="$genreGroup" userData="MALE"   style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 18;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                        <RadioButton fx:id="radioFemale" text="FEMALE" toggleGroup="$genreGroup" userData="FEMALE" style="-fx-background-color:white;-fx-background-radius:20px;-fx-border-color:#cccccc;-fx-border-radius:20px;-fx-padding:5 18;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                    </HBox>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label text="Date de naissance" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                    <DatePicker fx:id="dateNaissance" promptText="jj/mm/aaaa"
                                style="-fx-background-color: white; -fx-border-color: #cccccc;
                                       -fx-border-radius: 6px; -fx-background-radius: 6px;"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                    <Label text="Description" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                    <TextArea fx:id="description" prefHeight="80" wrapText="true"
                              style="-fx-background-color: white; -fx-border-color: #cccccc;
                                     -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 8px;"/>
                </VBox>
            </GridPane>

            <!-- État de santé -->
            <VBox spacing="10">
                <Label text="État de santé" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                <FlowPane hgap="12" vgap="10">
                    <CheckBox fx:id="vaccine"            text="Vacciné"            style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8 16;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                    <CheckBox fx:id="maladieContagieuse" text="Maladie contagieuse" style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8 16;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                    <CheckBox fx:id="dossierMedical"     text="Dossier médical"     style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8 16;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                    <CheckBox fx:id="etatCritique"       text="État critique"       style="-fx-background-color:white;-fx-border-color:#cccccc;-fx-border-radius:8px;-fx-background-radius:8px;-fx-padding:8 16;-fx-text-fill:#333333;-fx-mark-color:#9b72e8;-fx-label-padding:0 0 0 6;"/>
                </FlowPane>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnEnregistrer" text="Enregistrer" onAction="#handleEnregistrer"
                        style="-fx-background-color:#9b72e8;-fx-text-fill:white;-fx-font-size:14px;
                               -fx-font-weight:bold;-fx-background-radius:8px;-fx-padding:10 30;-fx-cursor:hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>

    <!-- ===================== FOOTER ===================== -->
    <VBox spacing="0" style="-fx-background-color:#1a0a2e;">
        <HBox spacing="0" style="-fx-padding:25px 40px 15px 40px;">
            <VBox spacing="8" prefWidth="280">
                <Label text="SITMYPET" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="L'application pour gérer la garde des animaux et connecter propriétaires et gardiens."
                       wrapText="true" style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
            </VBox>
            <VBox spacing="6" prefWidth="200">
                <Label text="Liens rapides" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Hyperlink text="Accueil"           onAction="#handleNavDashboard"    style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Hyperlink text="Publier une annonce" onAction="#handleNavAnnonces"   style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Hyperlink text="Voir les animaux"  onAction="#handleNavAnimaux"      style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Hyperlink text="Réclamations"      onAction="#handleNavReclamations" style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
            </VBox>
            <VBox spacing="6" prefWidth="200">
                <Label text="Support" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="Centre d'aide"  style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
                <Hyperlink text="Contactez-nous" style="-fx-text-fill:#9b72e8;-fx-font-size:11px;-fx-padding:0;"/>
                <Label text="FAQ" style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
            </VBox>
            <VBox spacing="6" prefWidth="200">
                <Label text="Contact" style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="contact@sitmypet.com" style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
                <Label text="+216 71 000 000"      style="-fx-font-size:11px;-fx-text-fill:#aaaacc;"/>
            </VBox>
        </HBox>
        <HBox style="-fx-padding:10px 40px;-fx-border-color:#2d1050 transparent transparent transparent;-fx-border-width:1;">
            <Label text="© 2026 SITMYPET. Tous droits réservés." style="-fx-font-size:10px;-fx-text-fill:#888899;"/>
        </HBox>
    </VBox>

</VBox>
