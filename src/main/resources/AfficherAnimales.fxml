<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ListeAnimauxController"
      prefWidth="1200" prefHeight="760"
      style="-fx-background-color: #f0f0f8; -fx-spacing: 0;">

    <!-- ===================== NAVBAR ===================== -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #1a0a2e;
                 -fx-padding: 0 30px;
                 -fx-min-height: 64px;
                 -fx-max-height: 64px;">

        <!-- Logo -->
        <VBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding: 0 30 0 0;">
            <Label text="🐾🐾" style="-fx-font-size: 20px;"/>
            <Label text="SitMyPet"
                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
        </VBox>

        <!-- Liens nav -->
        <Button text="🏠 Dashboard" onAction="#handleNavDashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-padding: 20 18;"/>

        <Button text="📣 Annonces" onAction="#handleNavAnnonces"
                style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-padding: 20 18;"/>

        <Button text="📅 Événements" onAction="#handleNavEvenements"
                style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-padding: 20 18;"/>

        <!-- Animaux — actif en jaune -->
        <Button text="🐾 Animaux" onAction="#handleNavAnimaux"
                style="-fx-background-color: transparent; -fx-text-fill: #f5c518;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-padding: 20 18;"/>

        <Button text="📩 Réclamations" onAction="#handleNavReclamations"
                style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-padding: 20 18;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Icônes droite -->
        <Button text="🔔"
                style="-fx-background-color: #2d1050; -fx-text-fill: white;
                       -fx-background-radius: 50%; -fx-font-size: 14px;
                       -fx-cursor: hand; -fx-padding: 8 10; -fx-min-width: 36;"/>
        <Region style="-fx-min-width: 8;"/>
        <Button text="🌙"
                style="-fx-background-color: #2d1050; -fx-text-fill: white;
                       -fx-background-radius: 50%; -fx-font-size: 14px;
                       -fx-cursor: hand; -fx-padding: 8 10; -fx-min-width: 36;"/>
        <Region style="-fx-min-width: 8;"/>
        <Button text="👤"
                style="-fx-background-color: #c084fc; -fx-text-fill: white;
                       -fx-background-radius: 50%; -fx-font-size: 14px;
                       -fx-cursor: hand; -fx-padding: 8 10; -fx-min-width: 36;"/>
    </HBox>

    <!-- ===================== CONTENU PRINCIPAL ===================== -->
    <VBox VBox.vgrow="ALWAYS" spacing="20"
          style="-fx-background-color: #f0f0f8; -fx-padding: 25px 30px;">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT">
            <Label text="🐾 Mes Animaux"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAjouter" text="+ Ajouter un animal" onAction="#handleAjouter"
                    style="-fx-background-color: #9b72e8; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8px; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>

        <!-- Filtres -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="searchNom" promptText="🔍 Nom" prefWidth="180"
                       style="-fx-background-color: white; -fx-border-color: #cccccc;
                              -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 7px 10px;"/>
            <ComboBox fx:id="filterType" promptText="Type" prefWidth="120"
                      style="-fx-background-color: white; -fx-border-color: #cccccc;
                             -fx-border-radius: 6px; -fx-background-radius: 6px;"/>
            <ComboBox fx:id="filterGenre" promptText="Genre" prefWidth="120"
                      style="-fx-background-color: white; -fx-border-color: #cccccc;
                             -fx-border-radius: 6px; -fx-background-radius: 6px;"/>
            <ComboBox fx:id="filterVaccine" promptText="Vacciné" prefWidth="120"
                      style="-fx-background-color: white; -fx-border-color: #cccccc;
                             -fx-border-radius: 6px; -fx-background-radius: 6px;"/>
            <ComboBox fx:id="filterCritique" promptText="Critique" prefWidth="120"
                      style="-fx-background-color: white; -fx-border-color: #cccccc;
                             -fx-border-radius: 6px; -fx-background-radius: 6px;"/>
            <Button text="Rechercher" onAction="#handleRechercher"
                    style="-fx-background-color: #9b72e8; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 6px; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="Réinitialiser" onAction="#handleReinitialiser"
                    style="-fx-background-color: #eeeeee; -fx-text-fill: #333333;
                           -fx-font-size: 13px; -fx-background-radius: 6px;
                           -fx-padding: 8 18; -fx-cursor: hand;"/>
        </HBox>

        <!-- Tableau -->
        <TableView fx:id="tableAnimaux" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-border-color: #eeeeee; -fx-border-radius: 8px;">
            <columns>
                <TableColumn fx:id="colPhoto"       text="photo"        prefWidth="80"/>
                <TableColumn fx:id="colNom"         text="Nom"          prefWidth="100"/>
                <TableColumn fx:id="colDate"        text="Date naissance" prefWidth="130"/>
                <TableColumn fx:id="colType"        text="Type"         prefWidth="90"/>
                <TableColumn fx:id="colRace"        text="Race"         prefWidth="90"/>
                <TableColumn fx:id="colPoids"       text="Poids"        prefWidth="70"/>
                <TableColumn fx:id="colDescription" text="Description"  prefWidth="150"/>
                <TableColumn fx:id="colGenre"       text="Genre"        prefWidth="80"/>
                <TableColumn fx:id="colVaccine"     text="Vacciné"      prefWidth="80"/>
                <TableColumn fx:id="colMaladie"     text="Maladie"      prefWidth="80"/>
                <TableColumn fx:id="colDossier"     text="Dossier"      prefWidth="80"/>
                <TableColumn fx:id="colCritique"    text="Critique"     prefWidth="80"/>
                <TableColumn fx:id="colActions"     text="Actions"      prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

    <!-- ===================== FOOTER ===================== -->
    <VBox spacing="0" style="-fx-background-color: #1a0a2e;">

        <!-- Contenu footer -->
        <HBox spacing="0" style="-fx-padding: 30px 40px 20px 40px;">

            <!-- Col 1 — Brand -->
            <VBox spacing="10" prefWidth="280">
                <Label text="SITMYPET"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="L'application pour gérer la garde des animaux&#10;et connecter propriétaires et gardiens&#10;facilement."
                       wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #aaaacc; -fx-line-spacing: 3;"/>
            </VBox>

            <!-- Col 2 — Liens rapides -->
            <VBox spacing="8" prefWidth="220">
                <Label text="Liens rapides"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Hyperlink text="Accueil" onAction="#handleNavDashboard"
                           style="-fx-text-fill: #9b72e8; -fx-font-size: 12px; -fx-padding: 0;"/>
                <Hyperlink text="Publier une annonce" onAction="#handleNavAnnonces"
                           style="-fx-text-fill: #9b72e8; -fx-font-size: 12px; -fx-padding: 0;"/>
                <Hyperlink text="Voir les animaux" onAction="#handleNavAnimaux"
                           style="-fx-text-fill: #9b72e8; -fx-font-size: 12px; -fx-padding: 0;"/>
                <Hyperlink text="Réclamations" onAction="#handleNavReclamations"
                           style="-fx-text-fill: #9b72e8; -fx-font-size: 12px; -fx-padding: 0;"/>
            </VBox>

            <!-- Col 3 — Support -->
            <VBox spacing="8" prefWidth="220">
                <Label text="Support"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Centre d'aide"
                       style="-fx-font-size: 12px; -fx-text-fill: #aaaacc;"/>
                <Hyperlink text="Contactez-nous"
                           style="-fx-text-fill: #9b72e8; -fx-font-size: 12px; -fx-padding: 0;"/>
                <Label text="FAQ"
                       style="-fx-font-size: 12px; -fx-text-fill: #aaaacc;"/>
            </VBox>

            <!-- Col 4 — Contact -->
            <VBox spacing="8" prefWidth="220">
                <Label text="Contact"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="contact@sitmypet.com"
                       style="-fx-font-size: 12px; -fx-text-fill: #aaaacc;"/>
                <Label text="+216 71 000 000"
                       style="-fx-font-size: 12px; -fx-text-fill: #aaaacc;"/>
            </VBox>
        </HBox>

        <!-- Copyright -->
        <HBox style="-fx-padding: 12px 40px; -fx-border-color: #2d1050 transparent transparent transparent; -fx-border-width: 1;">
            <Label text="© 2026 SITMYPET. Tous droits réservés."
                   style="-fx-font-size: 11px; -fx-text-fill: #888899;"/>
        </HBox>
    </VBox>

</VBox>
