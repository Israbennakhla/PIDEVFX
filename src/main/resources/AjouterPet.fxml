<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AjouterAnimalController"
      prefWidth="1200" prefHeight="760"
      style="-fx-background-color: #f0f0f8;">

   <!-- NAVBAR -->
   <HBox alignment="CENTER_LEFT" spacing="0"
         style="-fx-background-color:#1a0a2e;-fx-padding:0 30px;-fx-min-height:64px;-fx-max-height:64px;">
      <VBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding:0 30 0 0;">
         <Label text="SitMyPet" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:white;"/>
      </VBox>
      <Button text="Dashboard"    onAction="#handleNavDashboard"
              style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
      <Button text="Accueil"      onAction="#handleNavAccueil"
              style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
      <!-- Postulations actif -->
      <Button text="Postulations" onAction="#handleNavPostulations"
              style="-fx-background-color:transparent;-fx-text-fill:#f5c518;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
      <Button text="Annonces"     onAction="#handleNavAnnonces"
              style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
      <Button text="Evenements"   onAction="#handleNavEvenements"
              style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
      <Button text="Animaux"      onAction="#handleNavAnimaux"
              style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
      <Button text="Reclamations" onAction="#handleNavReclamations"
              style="-fx-background-color:transparent;-fx-text-fill:#cccccc;-fx-font-size:13px;-fx-font-weight:bold;-fx-cursor:hand;-fx-padding:20 18;"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="👤" style="-fx-background-color:#c084fc;-fx-text-fill:white;-fx-background-radius:50%;-fx-font-size:14px;-fx-cursor:hand;-fx-padding:8 10;-fx-min-width:36;"/>
   </HBox>

   <!-- CONTENU : ScrollPane avec un seul HBox vide que le controller remplit -->
   <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
               style="-fx-background-color:#f0f0f8;-fx-border-color:transparent;">
      <VBox spacing="20" style="-fx-padding:28px 60px;">

         <!-- Fil d'ariane + bouton retour -->
         <HBox alignment="CENTER_LEFT" spacing="12">
            <Button text="← Retour" onAction="#handleRetour"
                    style="-fx-background-color:transparent;-fx-text-fill:#9b72e8;-fx-font-size:13px;
                               -fx-font-weight:bold;-fx-cursor:hand;-fx-padding:0;"/>
            <Label text="/" style="-fx-text-fill:#aaaaaa;-fx-font-size:16px;"/>
            <Label text="Ajouter un animal"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#2d2d2d;"/>
         </HBox>

         <!--
             Ce HBox est le SEUL point d'ancrage injecté par le controller.
             Tout le formulaire (photo + champs) est construit en Java dans initialize().
             AUCUN onAction photo n'est dans ce FXML.
         -->
         <HBox fx:id="mainHBox" spacing="28" alignment="TOP_LEFT"/>

      </VBox>
   </ScrollPane>

   <!-- ToggleGroups déclarés ici pour injection @FXML -->
   <fx:define>
      <ToggleGroup fx:id="typeAnimalGroup"/>
      <ToggleGroup fx:id="genreGroup"/>
   </fx:define>

   <!-- FOOTER -->
   <VBox style="-fx-background-color:#1a0a2e;">
      <HBox style="-fx-padding:10px 40px;-fx-border-color:#2d1050 transparent transparent transparent;-fx-border-width:1;">
         <Label text="© 2026 SITMYPET. Tous droits réservés."
                style="-fx-font-size:10px;-fx-text-fill:#888899;"/>
      </HBox>
   </VBox>

</VBox>
